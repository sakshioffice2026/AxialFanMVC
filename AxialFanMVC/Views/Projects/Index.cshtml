@model AxialFanMVC.ViewModels.ProjectListViewModel
@{
    ViewData["Title"] = "My Projects";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-0"><i class="bi bi-folder2-open me-2 text-primary"></i>My Projects</h2>
        <small class="text-muted">@Model.Total project(s) total</small>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>New Project
    </a>
</div>

@if (!Model.Projects.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-folder-x display-3"></i>
        <p class="mt-3 lead">No projects yet.</p>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Create your first project
        </a>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var p in Model.Projects)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title mb-0">@p.Name</h5>
                            @{
                                var badgeClass = p.Status switch
                                {
                                    "active"   => "bg-success",
                                    "archived" => "bg-secondary",
                                    _          => "bg-warning text-dark"
                                };
                            }
                            <span class="badge @badgeClass">@p.Status</span>
                        </div>

                        @if (!string.IsNullOrEmpty(p.Description))
                        {
                            <p class="card-text text-muted small">@p.Description</p>
                        }

                        <div class="text-muted small mb-3">
                            <i class="bi bi-layers me-1"></i>@p.DesignCount design(s)
                            &nbsp;|&nbsp;
                            <i class="bi bi-clock me-1"></i>@p.UpdatedAt.ToLocalTime().ToString("dd MMM yyyy")
                        </div>

                        <div class="d-flex gap-2 flex-wrap">
                            <a asp-controller="Design" asp-action="Wizard"
                               asp-route-projectId="@p.Id"
                               class="btn btn-sm btn-primary">
                                <i class="bi bi-plus me-1"></i>New Design
                            </a>
                            <a asp-controller="Design" asp-action="History"
                               asp-route-projectId="@p.Id"
                               class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-clock-history me-1"></i>History
                            </a>
                            <a asp-action="Edit" asp-route-id="@p.Id"
                               class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@p.Id" method="post"
                                  onsubmit="return confirm('Delete project and all its designs?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                    <div class="card-footer text-muted small">
                        Created @p.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                    </div>
                </div>
            </div>
        }
    </div>

    @if (Model.Total > Model.PageSize)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= Math.Ceiling((double)Model.Total / Model.PageSize); i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
