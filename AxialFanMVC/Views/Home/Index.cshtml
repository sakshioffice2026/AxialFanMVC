@{
    ViewData["Title"] = "Welcome";
    ViewData["HideBackButton"] = true;
}

<div class="text-center py-5">
    <i class="bi bi-fan display-1 text-primary"></i>
    <h1 class="mt-3 display-5 fw-bold">AxialFlow Designer</h1>
    <p class="lead text-muted mb-4">
        Professional axial fan design and performance analysis tool
    </p>
    <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg me-2">
        <i class="bi bi-person-plus me-1"></i>Get Started Free
    </a>
    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary btn-lg">
        Sign In
    </a>
</div>

<div class="row g-4 mt-2">
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm text-center p-4">
            <i class="bi bi-calculator display-5 text-primary mb-3"></i>
            <h5>Aerodynamic Calculations</h5>
            <p class="text-muted">
                Specific speed, tip speed, flow and pressure coefficients,
                shaft power — all computed instantly.
            </p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm text-center p-4">
            <i class="bi bi-graph-up display-5 text-success mb-3"></i>
            <h5>Performance Curves</h5>
            <p class="text-muted">
                Q-ΔP, Q-η and Q-kW curves for any blade angle
                and speed combination.
            </p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm text-center p-4">
            <i class="bi bi-shield-check display-5 text-warning mb-3"></i>
            <h5>Structural Analysis</h5>
            <p class="text-muted">
                Centrifugal stress, bending stress and safety factor
                checks against Al 6061-T6.
            </p>
        </div>
    </div>
</div>

