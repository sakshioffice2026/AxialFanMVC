@model AxialFanMVC.ViewModels.DesignSeriesDetailsViewModel
@{
    ViewData["Title"] = Model.Name;
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Projects" asp-action="Index">Projects</a></li>
            <a asp-controller="Projects"
               asp-action="Index"
               class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i>New Series
            </a>
            <li class="breadcrumb-item active">@Model.Name</li>
        </ol>
    </nav>
    <h2><i class="bi bi-layers me-2 text-primary"></i>@Model.Name</h2>
    <p class="text-muted">Base design: @Model.BaseDesignLabel &middot; Created @Model.CreatedAt.ToString("dd MMM yyyy")</p>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table mb-0 align-middle">
            <thead>
                <tr>
                    <th>Tip Diameter</th>
                    <th>Flow Rate</th>
                    <th>Total Pressure</th>
                    <th>Motor Power</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var v in Model.Variants)
                {
                    <tr>
                        <td>@v.TipDiameterMm.ToString("F0") mm</td>
                        <td>@v.FlowRateM3s.ToString("F2") m³/s</td>
                        <td>@v.TotalPressurePa.ToString("F0") Pa</td>
                        <td>@v.MotorPowerKw.ToString("F2") kW</td>
                        <td>
                            @if (v.HasBeenCalculated)
                            {
                                <span class="badge bg-success">Calculated</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Not calculated</span>
                            }
                        </td>
                        <td>
                            @if (v.HasBeenCalculated)
                            {
                                <a asp-controller="Results" asp-action="Result" asp-route-resultId="@v.ResultId" class="btn btn-sm btn-outline-primary">View Result</a>
                            }
                            else
                            {
                                <a asp-controller="Design" asp-action="EditInput" asp-route-designInputId="@v.DesignInputId" class="btn btn-sm btn-primary">Calculate</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>