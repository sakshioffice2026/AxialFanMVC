@model AxialFanMVC.ViewModels.DesignResultViewModel
@{
    ViewData["Title"] = $"Results — {Model.ProjectName}";
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-controller="Projects" asp-action="Index">Projects</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="Design" asp-action="History"
                   asp-route-projectId="@Model.ProjectId">@Model.ProjectName</a>
            </li>
            <li class="breadcrumb-item active">Design Result #@Model.ResultId</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <h2 class="mb-1">
                <i class="bi bi-bar-chart-line me-2 text-primary"></i>Design Result
                @{
                    var (headerBadge, headerIcon) = Model.Status switch
                    {
                        "ok" => ("bg-success", "bi-check-circle-fill"),
                        "warning" => ("bg-warning text-dark", "bi-exclamation-triangle-fill"),
                        _ => ("bg-danger", "bi-x-circle-fill")
                    };
                }
                <span class="badge @headerBadge ms-2 fs-6">
                    <i class="bi @headerIcon me-1"></i>@Model.Status.ToUpper()
                </span>
            </h2>
            <small class="text-muted">
                Calculated @Model.CalculatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                &nbsp;|&nbsp; Result ID: #@Model.ResultId
            </small>
        </div>

        @* {{!-- Action Buttons --}} *@
        <div class="d-flex flex-wrap gap-2">
            @* {{!-- New Design --}} *@
            <a asp-controller="Design" asp-action="Wizard"
               asp-route-projectId="@Model.ProjectId"
               class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i>New Design
            </a>
            @* {{!-- Edit This Design --}} *@
            <a asp-controller="Design" asp-action="EditInput"
               asp-route-designInputId="@Model.DesignInputId"
               class="btn btn-outline-primary">
                <i class="bi bi-pencil me-1"></i>Edit
            </a>

            @* {{!-- View History --}} *@
            <a asp-controller="Design" asp-action="History"
               asp-route-projectId="@Model.ProjectId"
               class="btn btn-outline-secondary">
                <i class="bi bi-clock-history me-1"></i>History
            </a>

            @* {{!-- Export Dropdown --}} *@
            <div class="dropdown">
                <button class="btn btn-success dropdown-toggle"
                        type="button" data-bs-toggle="dropdown">
                    <i class="bi bi-download me-1"></i>Save / Export
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow">
                    <li>
                        <h6 class="dropdown-header">
                            <i class="bi bi-file-earmark me-1"></i>Export Options
                        </h6>
                    </li>
                    <li>
                        <a class="dropdown-item"
                           asp-controller="Export"
                           asp-action="Csv"
                           asp-route-resultId="@Model.ResultId">
                            <i class="bi bi-filetype-csv me-2 text-success"></i>
                            Export as CSV
                            <small class="text-muted d-block ps-4">
                                All data in spreadsheet format
                            </small>
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item"
                           asp-controller="Export"
                           asp-action="Report"
                           asp-route-resultId="@Model.ResultId">
                            <i class="bi bi-file-earmark-text me-2 text-primary"></i>
                            HTML Report
                            <small class="text-muted d-block ps-4">
                                Printable full design report
                            </small>
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item"
                           asp-controller="Export"
                           asp-action="Drawings"
                           asp-route-resultId="@Model.ResultId">
                            <i class="bi bi-rulers me-2 text-secondary"></i>
                            Engineering Drawings
                            <small class="text-muted d-block ps-4">
                                SVG technical drawings
                            </small>
                        </a>
                    </li>
                    <li><hr class="dropdown-divider" /></li>
                    <li>
                        <a class="dropdown-item" href="#" onclick="window.print()">
                            <i class="bi bi-printer me-2 text-dark"></i>
                            Print This Page
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

@if (Model.Warnings.Any())
{
    <div class="alert alert-warning mb-4">
        <h6 class="alert-heading"><i class="bi bi-exclamation-triangle me-1"></i>Design Warnings</h6>
        <ul class="mb-0 ps-3">
            @foreach (var w in Model.Warnings)
            {
                <li>@w</li>
            }
        </ul>
    </div>
}

<div class="row g-4">


    <div class="col-lg-3">
        <div class="card shadow-sm">
            <div class="card-header bg-light fw-semibold">
                <i class="bi bi-input-cursor-text me-1 text-secondary"></i>Input Parameters
            </div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <tbody>
                        <tr><td class="text-muted ps-3">Flow Rate</td><td class="fw-semibold">@Model.FlowRateM3s.ToString("F3") m³/s</td></tr>
                        <tr><td class="text-muted ps-3">Total Pressure</td><td class="fw-semibold">@Model.TotalPressurePa.ToString("F0") Pa</td></tr>
                        <tr><td class="text-muted ps-3">Speed</td><td class="fw-semibold">@Model.SpeedRpm RPM</td></tr>
                        <tr><td class="text-muted ps-3">Blade Count</td><td class="fw-semibold">@Model.BladeCount</td></tr>
                        <tr><td class="text-muted ps-3">Tip Diameter</td><td class="fw-semibold">@Model.TipDiameterMm.ToString("F0") mm</td></tr>
                        <tr><td class="text-muted ps-3">Blade Angle</td><td class="fw-semibold">@Model.BladeAngleDeg.ToString("F1") °</td></tr>
                        <tr><td class="text-muted ps-3">Blade Profile</td><td class="fw-semibold">@(Model.BladeProfileName ?? "—")</td></tr>
                        <tr>
                            <td>Overall Noise</td>
                            <td>@(Model.OverallNoiseDbA?.ToString("F1") ?? "—") dB(A)</td>
                        </tr>

                        <tr>
                            <td>Sound Power</td>
                            <td>@(Model.SoundPowerLevelDb?.ToString("F1") ?? "—") dB</td>
                        </tr>

                        <tr>
                            <td>Blade Passing Frequency</td>
                            <td>@(Model.BladePassingFrequencyHz?.ToString("F1") ?? "—") Hz</td>
                        </tr>

                        <tr>
                            <td>Tip Mach Number</td>
                            <td>@(Model.TipMachNumber?.ToString("F3") ?? "—")</td>
                        </tr>

                        <tr>
                            <td>Noise Rating</td>
                            <td>@Model.NoiseRating (@(Model.NoiseRatingValue?.ToString("F1") ?? "—"))</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-3">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white fw-semibold">
                <i class="bi bi-wind me-1"></i>Aerodynamic Results
            </div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <tbody>
                        <tr><td class="text-muted ps-3">Specific Speed (Ω<sub>s</sub>)</td><td class="fw-semibold">@Model.SpecificSpeed.ToString("F4")</td></tr>
                        <tr><td class="text-muted ps-3">Tip Speed</td><td class="fw-semibold">@Model.TipSpeedMs.ToString("F2") m/s</td></tr>
                        <tr><td class="text-muted ps-3">Hub Diameter</td><td class="fw-semibold">@Model.HubDiameterMm.ToString("F1") mm</td></tr>
                        <tr><td class="text-muted ps-3">Blade Span</td><td class="fw-semibold">@Model.BladeSpanMm.ToString("F1") mm</td></tr>
                        @* <tr><td class="text-muted ps-3">Chord Length</td><td class="fw-semibold">@Model.ChordLengthMm.ToString("F1") mm</td></tr> *@
                        @* <tr><td class="text-muted ps-3">Flow Coefficient Φ</td><td class="fw-semibold">@Model.FlowCoefficient.ToString("F4")</td></tr> *@
                        @* <tr><td class="text-muted ps-3">Pressure Coefficient Ψ</td><td class="fw-semibold">@Model.PressureCoefficient.ToString("F4")</td></tr> *@
                        <tr class="table-success"><td class="ps-3 fw-semibold">Overall Efficiency</td><td class="fw-bold text-success">@Model.OverallEfficiencyPct.ToString("F1") %</td></tr>
                        <tr class="table-primary"><td class="ps-3 fw-semibold">Shaft Power</td><td class="fw-bold">@Model.ShaftPowerKw.ToString("F3") kW</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-3">
        <div class="card shadow-sm">
            <div class="card-header bg-warning text-dark fw-semibold">
                <i class="bi bi-shield-check me-1"></i>Structural Results
            </div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <tbody>
                        <tr><td class="text-muted ps-3">Material</td><td class="fw-semibold">Al 6061-T6</td></tr>
                        <tr><td class="text-muted ps-3">Yield Strength</td><td class="fw-semibold">270 MPa</td></tr>
                        <tr><td class="text-muted ps-3">Tip Clearance</td><td class="fw-semibold">@Model.TipClearanceMm.ToString("F1") mm</td></tr>
                        <tr><td class="text-muted ps-3">Blade Stress</td><td class="fw-semibold">@Model.BladeStressMpa.ToString("F2") MPa</td></tr>
                        <tr>
                            <td class="ps-3 fw-semibold">Safety Factor</td>
                            <td>
                                @{
                                    var sfClass = Model.SafetyFactor >= 2.0 ? "text-success fw-bold" : "text-danger fw-bold";
                                }
                                <span class="@sfClass">@Model.SafetyFactor.ToString("F2")</span>
                                @if (Model.SafetyFactor >= 2.0)
                                {
                                    <i class="bi bi-check-circle text-success ms-1"></i>
                                }
                                else
                                {
                                    <i class="bi bi-exclamation-triangle text-danger ms-1"></i>
                                }
                            </td>
                        </tr>
                    </tbody>
                </table>
                <div class="p-3">
                    <div class="d-flex justify-content-between small text-muted mb-1">
                        <span>Safety margin</span>
                        <span>Min: 2.0</span>
                    </div>
                    @{
                        var sfPct = Math.Min((Model.SafetyFactor / 4.0) * 100, 100);
                        var sfBarClass = Model.SafetyFactor >= 2.0 ? "bg-success" : "bg-danger";
                    }
                    <div class="progress" style="height: 12px;">
                        <div class="progress-bar @sfBarClass" style="width: @sfPct.ToString("F0")%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3">
        <div class="card shadow-sm">
            <div class="card-header bg-warning text-dark fw-semibold">
                <i class="bi bi-shield-check me-1"></i>Structural Results
            </div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <tbody>
                        <tr><td class="text-muted ps-3">Material</td><td class="fw-semibold">Al 6061-T6</td></tr>
                        <tr><td class="text-muted ps-3">Yield Strength</td><td class="fw-semibold">270 MPa</td></tr>
                        <tr><td class="text-muted ps-3">Tip Clearance</td><td class="fw-semibold">@Model.TipClearanceMm.ToString("F1") mm</td></tr>
                        <tr><td class="text-muted ps-3">Blade Stress</td><td class="fw-semibold">@Model.BladeStressMpa.ToString("F2") MPa</td></tr>
                        <tr>
                            <td class="ps-3 fw-semibold">Safety Factor</td>
                            @* <td>
                                @{
                                    var sfClass = Model.SafetyFactor >= 2.0 ? "text-success fw-bold" : "text-danger fw-bold";
                                }
                                <span class="@sfClass">@Model.SafetyFactor.ToString("F2")</span>
                                @if (Model.SafetyFactor >= 2.0)
                                {
                                    <i class="bi bi-check-circle text-success ms-1"></i>
                                }
                                else
                                {
                                    <i class="bi bi-exclamation-triangle text-danger ms-1"></i>
                                }
                            </td> *@
                        </tr>
                    </tbody>
                </table>
                <div class="p-3">
                    <div class="d-flex justify-content-between small text-muted mb-1">
                        <span>Safety margin</span>
                        <span>Min: 2.0</span>
                    </div>
                    @* @{
                        var sfPct = Math.Min((Model.SafetyFactor / 4.0) * 100, 100);
                        var sfBarClass = Model.SafetyFactor >= 2.0 ? "bg-success" : "bg-danger";
                    } *@
                    <div class="progress" style="height: 12px;">
                        <div class="progress-bar @sfBarClass" style="width: @sfPct.ToString("F0")%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.BaselineComparison != null && Model.PinnComparison != null)
    {
        var pressureDiff = Model.PinnComparison.PressurePa - Model.BaselineComparison.PressurePa;
        var pressurePct = pressureDiff / Model.BaselineComparison.PressurePa * 100.0;

        var effDiff = Model.PinnComparison.EfficiencyPct - Model.BaselineComparison.EfficiencyPct;
        var powerDiff = Model.PinnComparison.PowerKw - Model.BaselineComparison.PowerKw;

        <div class="col-12 mt-4">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white fw-semibold">
                    <i class="bi bi-columns-gap me-2"></i>
                    Baseline vs PINN Corrected Comparison
                </div>

                <div class="card-body p-0">

                    <table class="table table-bordered table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:30%">Parameter</th>
                                <th class="text-center text-primary">
                                    Response 1<br />
                                    <small>Baseline CFD</small>
                                </th>
                                <th class="text-center text-danger">
                                    Response 2<br />
                                    <small>PINN Corrected</small>
                                </th>
                                <th class="text-center">
                                    Difference
                                </th>
                            </tr>
                        </thead>

                        <tbody>

                            <tr>
                                <td>Total Pressure</td>

                                <td class="text-center">
                                    @Model.BaselineComparison.PressurePa.ToString("F1") Pa
                                </td>

                                <td class="text-center">
                                    @Model.PinnComparison.PressurePa.ToString("F1") Pa
                                </td>

                                <td class="text-center">
                                    @(pressureDiff >= 0 ? "+" : "")
                                    @pressureDiff.ToString("F1") Pa
                                    <br />
                                    <small class="text-muted">
                                        (@pressurePct.ToString("F2")%)
                                    </small>
                                </td>
                            </tr>

                            <tr>
                                <td>Overall Efficiency</td>

                                <td class="text-center">
                                    @Model.BaselineComparison.EfficiencyPct.ToString("F2") %
                                </td>

                                <td class="text-center">
                                    @Model.PinnComparison.EfficiencyPct.ToString("F2") %
                                </td>

                                <td class="text-center">
                                    @(effDiff >= 0 ? "+" : "")
                                    @effDiff.ToString("F2") %
                                </td>
                            </tr>

                            <tr>
                                <td>Shaft Power</td>

                                <td class="text-center">
                                    @Model.BaselineComparison.PowerKw.ToString("F3") kW
                                </td>

                                <td class="text-center">
                                    @Model.PinnComparison.PowerKw.ToString("F3") kW
                                </td>

                                <td class="text-center">
                                    @(powerDiff >= 0 ? "+" : "")
                                    @powerDiff.ToString("F3") kW
                                </td>
                            </tr>

                            <tr>
                                <td>Peak Pressure</td>

                                <td class="text-center">
                                    @Model.BaselineComparison.PeakPressurePa.ToString("F1") Pa
                                </td>

                                <td class="text-center">
                                    @Model.PinnComparison.PeakPressurePa.ToString("F1") Pa
                                </td>

                                <td class="text-center">
                                    @((Model.PinnComparison.PeakPressurePa -
                                                                    Model.BaselineComparison.PeakPressurePa).ToString("F1")) Pa
                                                                                                                        </td>
                                                                                                                    </tr>

                            <tr>
                                <td>Peak Efficiency</td>

                                <td class="text-center">
                                    @Model.BaselineComparison.PeakEfficiencyPct.ToString("F2") %
                                </td>

                                <td class="text-center">
                                    @Model.PinnComparison.PeakEfficiencyPct.ToString("F2") %
                                </td>

                                <td class="text-center">
                                    @((Model.PinnComparison.PeakEfficiencyPct -
                                                                    Model.BaselineComparison.PeakEfficiencyPct).ToString("F2")) %
                            </td>
                        </tr>

                        </tbody>
                    </table>

                </div>

                <div class="card-footer bg-light">

                @{
                        var better =
                        effDiff > 0 && pressureDiff > 0
                        ? "PINN correction improves the predicted performance over the baseline."
                        : "PINN correction shows little or no improvement over the baseline.";
                    }

                    <span class="fw-semibold">
                        <i class="bi bi-lightbulb text-warning me-1"></i>
                        Summary
                    </span>

                    <div class="mt-2">
                        @better
                    </div>

                </div>
            </div>
        </div>
    }

    @* {{!-- ── Performance Curves Chart ── --}} *@
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header bg-light fw-semibold">
                <span>
                    <i class="bi bi-graph-up me-1 text-primary"></i>
                    Performance Curves
                </span>
            </div>

            @* {{!-- Slider Controls --}} *@
            <div class="card-body border-bottom pb-3">
                <div class="row g-3 align-items-center">

                    @* {{!-- Blade Angle Slider --}} *@
                    <div class="col-md-6">
                        <div class="d-flex justify-content-between mb-1">
                            <label class="form-label fw-semibold mb-0">
                                <i class="bi bi-gear me-1 text-primary"></i>
                                Blade Angle (β)
                            </label>
                            <span class="badge bg-primary fs-6"
                                  id="labelAngle">
                                @Model.BladeAngleDeg °
                            </span>
                        </div>
                        <input type="range"
                               class="form-range"
                               id="sliderAngle"
                               min="5" max="50" step="1"
                               value="@Model.BladeAngleDeg" />
                        <div class="d-flex justify-content-between
                                small text-muted mt-1">
                            <span>5° (flat)</span>
                            <span>27° (design point)</span>
                            <span>50° (steep)</span>
                        </div>
                    </div>

                    @*  {{!-- RPM Slider --}} *@
                    <div class="col-md-6">
                        <div class="d-flex justify-content-between mb-1">
                            <label class="form-label fw-semibold mb-0">
                                <i class="bi bi-lightning-charge me-1
                               text-warning"></i>
                                Fan Speed (N)
                            </label>
                            <span class="badge bg-warning text-dark fs-6"
                                  id="labelRpm">
                                @Model.SpeedRpm RPM
                            </span>
                        </div>
                        <input type="range"
                               class="form-range"
                               id="sliderRpm"
                               min="500" max="3000" step="50"
                               value="@Model.SpeedRpm" />
                        <div class="d-flex justify-content-between
                                small text-muted mt-1">
                            <span>500 RPM</span>
                            <span>1500 RPM</span>
                            <span>3000 RPM</span>
                        </div>
                    </div>

                    @* {{!-- Current Values Summary --}} *@
                    <div class="col-12">
                        <div class="alert alert-light border mb-0 py-2">
                            <div class="row text-center small">
                                <div class="col-4 border-end">
                                    <div class="text-muted">Blade Angle</div>
                                    <div class="fw-bold text-primary fs-5"
                                         id="displayAngle">
                                        @Model.BladeAngleDeg °
                                    </div>
                                    <div class="text-muted" style="font-size:0.7rem;">
                                        β — pitch angle from rotor plane
                                    </div>
                                </div>
                                <div class="col-4 border-end">
                                    <div class="text-muted">Fan Speed</div>
                                    <div class="fw-bold text-warning fs-5"
                                         id="displayRpm">
                                        @Model.SpeedRpm RPM
                                    </div>
                                    <div class="text-muted" style="font-size:0.7rem;">
                                        N — rotational speed
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="text-muted">Status</div>
                                    <div class="fw-bold text-success fs-5"
                                         id="displayStatus">
                                        Ready
                                    </div>
                                    <div class="text-muted" style="font-size:0.7rem;">
                                        curve generation status
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    @*  {{!-- Regenerate / Pin / Reset Buttons --}} *@
                    <div class="col-12 text-end">
                        <button id="btnGenCurve"
                                class="btn btn-primary px-4">
                            <i class="bi bi-arrow-repeat me-1"></i>
                            Regenerate Curves
                        </button>
                        <button id="btnPinCurve"
                                class="btn btn-outline-primary ms-2" disabled>
                            <i class="bi bi-pin-angle-fill me-1"></i>
                            Pin Curve
                        </button>
                        <button id="btnResetCurve"
                                class="btn btn-outline-secondary ms-2">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>
                            Reset to Design Point
                        </button>
                    </div>

                </div>
            </div>

            @*       {{!-- Charts --}} *@
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <div class="border rounded p-2 bg-white">
                            <div class="text-center small text-muted mb-1 fw-semibold">
                                <i class="bi bi-graph-down me-1 text-primary"></i>
                                Pressure Rise Curve  Q — ΔP
                            </div>
                            <canvas id="chartQdp" height="200"></canvas>
                        </div>
                    </div>
                    <div class="col-12 col-md-6">
                        <div class="border rounded p-2 bg-white">
                            <div class="text-center small text-muted mb-1 fw-semibold">
                                <i class="bi bi-graph-up me-1 text-success"></i>
                                Efficiency &amp; Power Curve  Q — η — kW
                            </div>
                            <canvas id="chartEta" height="200"></canvas>
                        </div>
                    </div>
                </div>

                @* {{!-- NEW: Curve Comparison / Pin table --}} *@
                <div class="mt-3" id="curveCompareBlock">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="fw-semibold small text-muted text-uppercase" style="letter-spacing:.03em">
                            Curve Comparison
                        </span>
                        <span class="small text-muted" id="curveCountLabel">1 / 10 curves</span>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0" id="curveCompareTable">
                            <thead>
                                <tr class="small text-muted">
                                    <th style="width:24px"></th>
                                    <th>Curve</th>
                                    <th>Blade Angle</th>
                                    <th>Speed</th>
                                    <th style="width:70px">Pin</th>
                                    <th style="width:40px"></th>
                                </tr>
                            </thead>
                            <tbody id="curveCompareBody">
                                <!-- rows injected by JS -->
                            </tbody>
                        </table>
                    </div>
                    <div class="alert alert-warning small mt-2 mb-0 d-none" id="curveLimitAlert">
                        Maximum of 10 comparison curves reached.
                    </div>
                </div>

                @*   {{!-- Legend explanation --}} *@
                <div class="mt-3 p-3 bg-light rounded border small">
                    <div class="row g-2">
                        <div class="col-md-3">
                            <span class="badge bg-primary me-1">Q</span>
                            Volume flow rate (m³/s)
                        </div>
                        <div class="col-md-3">
                            <span class="badge bg-primary me-1">ΔP</span>
                            Total pressure rise (Pa)
                        </div>
                        <div class="col-md-3">
                            <span class="badge bg-success me-1">η</span>
                            Overall efficiency (%)
                        </div>
                        <div class="col-md-3">
                            <span class="badge bg-danger me-1">kW</span>
                            Shaft power (kilowatts)
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
    @if (Model.Drawings.Any())
    {
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white fw-semibold">
                    <i class="bi bi-rulers me-1"></i>Engineering Drawings
                    <span class="badge bg-light text-primary ms-2">@Model.Drawings.Count DXF files ready</span>
                </div>
                <div class="card-body">
                    @{
                        var dwgTitles = new Dictionary<string, (string, string, string)>
                        {
                            ["front_elevation"] = ("DWG-001", "Front Elevation", "bi-circle"),
                            ["cross_section"] = ("DWG-002", "Cross Section", "bi-layout-split"),
                            ["blade_profile"] = ("DWG-003", "Blade Aerofoil Profile", "bi-bezier2"),
                            ["blade_angle"] = ("DWG-004", "Blade Angle Detail", "bi-triangle"),
                            ["hub_detail"] = ("DWG-005", "Hub Detail", "bi-gear-wide"),
                            ["casing_detail"] = ("DWG-006", "Casing + Motor Mounting", "bi-box"),
                            ["general_arrangement"] = ("DWG-007", "General Arrangement + BOM", "bi-diagram-3"),
                        };
                    }
                    <div class="row g-3">
                        @foreach (var drw in Model.Drawings)
                        {
                            var info = dwgTitles.ContainsKey(drw.DrawingType)
                            ? dwgTitles[drw.DrawingType]
                            : ("DWG", drw.DrawingType.Replace("_", " ").ToUpperInvariant(), "bi-file");
                            string dwgCode = info.Item1;
                            string dwgTitle = info.Item2;
                            string dwgIcon = info.Item3;
                            <div class="col-md-4 col-lg-3">
                                <div class="card border h-100">
                                    <div class="card-header small fw-semibold bg-light d-flex align-items-center gap-2">
                                        <i class="bi @dwgIcon text-primary"></i>
                                        <span>@dwgCode</span>
                                    </div>
                                    <div class="card-body text-center py-3">
                                        <i class="bi bi-file-earmark-text display-4 text-primary opacity-75"></i>
                                        <p class="small fw-semibold mt-2 mb-1">@dwgTitle</p>
                                        <p class="small text-muted mb-0">CAD Drawing Ready</p>
                                    </div>
                                    <div class="card-footer">
                                        @*  @if (drw.HasDxf)
                                        {
                                            <a asp-controller="Results" asp-action="Download"
                                               asp-route-drawingId="@drw.Id" asp-route-format="dxf"
                                               class="btn btn-sm btn-primary w-100">
                                                <i class="bi bi-download me-1"></i>Download DXF
                                            </a>
                                        } *@
                                        <div class="card-footer">
                                            <li>
                                                <a class="dropdown-item" href="#" id="btnDownloadPdf">
                                                    <i class="bi bi-filetype-pdf me-2 text-danger"></i>
                                                    Download PDF Summary
                                                    <small class="text-muted d-block ps-4">
                                                        Results + charts exactly as shown on screen
                                                    </small>
                                                </a>
                                            </li>

                                            <div class="d-flex flex-column gap-2">

                                                <a asp-controller="Export"
                                                   asp-action="EyeshotDwg"
                                                   asp-route-resultId="@Model.ResultId"
                                                   asp-route-drawing="@drw.DrawingType"
                                                   class="btn btn-sm btn-primary w-100"
                                                   onclick="this.innerHTML='Generating DWG...'">
                                                    <i class="bi bi-download me-1"></i>Download DWG
                                                </a>

                                                <a asp-controller="Export"
                                                   asp-action="EyeshotPdf"
                                                   asp-route-resultId="@Model.ResultId"
                                                   asp-route-drawing="@drw.DrawingType"
                                                   class="btn btn-sm btn-outline-danger w-100"
                                                   onclick="this.innerHTML='Generating PDF...'">
                                                    <i class="bi bi-filetype-pdf me-1"></i>Download PDF
                                                </a>

                                            </div>

                                        </div>
                                    </div>

                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

</div>
@section Scripts {
    <script>
        // ── Initial curve data from server ───────────────────────────
        const initialCurves = @Html.Raw(Model.CurveJson);
        const designAngle  = @Model.BladeAngleDeg;
        const designRpm    = @Model.SpeedRpm;
        const resultId     = @Model.ResultId;

        const MAX_CURVES = 10;
        const COLOR_PALETTE = [
            '#dc3545', // red
            '#198754', // green
            '#fd7e14', // orange
            '#6f42c1', // purple
            '#795548', // brown
            '#d63384', // pink
            '#20c997', // teal
            '#212529', // black
            '#0dcaf0', // cyan
        ];
        const DESIGN_COLOR = '#0d6efd'; // blue — reserved for the design curve only

        // Line weights tuned for a "premium" look: thin, crisp lines with
        // slightly larger hover points instead of chunky always-on markers.
        const DESIGN_LINE_WIDTH  = 2.25;
        const CURVE_LINE_WIDTH   = 1.5;
        const DESIGN_KW_WIDTH    = 1.5;
        const CURVE_KW_WIDTH     = 1;

        // ── Curve state ───────────────────────────────────────────────
        // Each curve: { id, label, angle, rpm, color, pinned, isDesign, temporary, q, dp, eta, kw }
               let curves = [];

        if (initialCurves.baseline) {
            curves.push({
                id: "baseline",
                label: "Baseline",
                angle: designAngle,
                rpm: designRpm,
                color: "#0d6efd",
                pinned: true,
                isDesign: true,
                temporary: false,

                q: initialCurves.baseline.q,
                dp: initialCurves.baseline.dp,
                eta: initialCurves.baseline.eta,
                kw: initialCurves.baseline.kw
            });
        }

        if (initialCurves.corrected) {
            curves.push({
                id: "pinn",
                label: "PINN Corrected",
                angle: designAngle,
                rpm: designRpm,
                color: "#dc3545",
                pinned: true,
                isDesign: false,
                temporary: false,

                q: initialCurves.corrected.q,
                dp: initialCurves.corrected.dp,
                eta: initialCurves.corrected.eta,
                kw: initialCurves.corrected.kw
            });
        }

        let usedColors = new Set();
        function nextColor() {
            const free = COLOR_PALETTE.find(c => !usedColors.has(c));
            if (free) { usedColors.add(free); return free; }
            return COLOR_PALETTE[curves.length % COLOR_PALETTE.length];
        }
        function releaseColor(color) {
            usedColors.delete(color);
        }

        // ── Chart.js setup (empty shells — populated by render()) ─────
        const commonScalesX = { title: { display: true, text: 'Flow Rate Q (m³/s)' } };

        const ctxQdp = document.getElementById('chartQdp').getContext('2d');
        const chartQdp = new Chart(ctxQdp, {
            type: 'line',
            data: { labels: [], datasets: [] },
            options: {
                responsive: true,
                plugins: {
                    legend: { display: false },
                    tooltip: { mode: 'index', intersect: false }
                },
                interaction: { mode: 'index', intersect: false },
                scales: {
                    x: commonScalesX,
                    y: { title: { display: true, text: 'ΔP (Pa)' } }
                }
            }
        });

        const ctxEta = document.getElementById('chartEta').getContext('2d');
        const chartEta = new Chart(ctxEta, {
            type: 'line',
            data: { labels: [], datasets: [] },
            options: {
                responsive: true,
                plugins: {
                    legend: { display: false },
                    tooltip: { mode: 'index', intersect: false }
                },
                interaction: { mode: 'index', intersect: false },
                scales: {
                    x: commonScalesX,
                    yEta: { type: 'linear', position: 'left', title: { display: true, text: 'η (%)' } },
                    yKw: { type: 'linear', position: 'right', title: { display: true, text: 'kW' }, grid: { drawOnChartArea: false } }
                }
            }
        });

        // ── Render everything from `curves` state ─────────────────────
        function render() {
            const labelSource = curves.reduce((a, b) => (a.q.length >= b.q.length ? a : b));

            chartQdp.data.labels = labelSource.q;
            chartQdp.data.datasets = curves.map(c => ({
                label: c.label,
                data: c.dp,
                borderColor: c.color,
                backgroundColor: c.color + '12',
                borderWidth: c.isDesign ? DESIGN_LINE_WIDTH : CURVE_LINE_WIDTH,
                borderCapStyle: 'round',
                borderJoinStyle: 'round',
                borderDash: c.isDesign ? [] : [5, 3],
                fill: c.isDesign,
                tension: 0.35,
                cubicInterpolationMode: 'monotone',
                pointRadius: 0,
                pointHoverRadius: c.isDesign ? 5 : 4,
                pointHoverBackgroundColor: c.color,
                pointHoverBorderColor: '#fff',
                pointHoverBorderWidth: 2
            }));
            chartQdp.update();

            chartEta.data.labels = labelSource.q;
            chartEta.data.datasets = curves.flatMap(c => ([
                {
                    label: `${c.label} — η`,
                    data: c.eta,
                    borderColor: c.color,
                    borderWidth: c.isDesign ? DESIGN_LINE_WIDTH : CURVE_LINE_WIDTH,
                    borderCapStyle: 'round',
                    borderJoinStyle: 'round',
                    borderDash: c.isDesign ? [] : [5, 3],
                    fill: false,
                    tension: 0.35,
                    cubicInterpolationMode: 'monotone',
                    pointRadius: 0,
                    pointHoverRadius: c.isDesign ? 5 : 4,
                    pointHoverBackgroundColor: c.color,
                    pointHoverBorderColor: '#fff',
                    pointHoverBorderWidth: 2,
                    yAxisID: 'yEta'
                },
                {
                    label: `${c.label} — kW`,
                    data: c.kw,
                    borderColor: c.color,
                    borderWidth: c.isDesign ? DESIGN_KW_WIDTH : CURVE_KW_WIDTH,
                    borderCapStyle: 'round',
                    borderJoinStyle: 'round',
                    borderDash: c.isDesign ? [2, 2] : [1, 3],
                    fill: false,
                    tension: 0.35,
                    cubicInterpolationMode: 'monotone',
                    pointRadius: 0,
                    pointHoverRadius: c.isDesign ? 4 : 3,
                    pointHoverBackgroundColor: c.color,
                    pointHoverBorderColor: '#fff',
                    pointHoverBorderWidth: 2,
                    yAxisID: 'yKw'
                }
            ]));
            chartEta.update();

            renderTable();
        }

        function renderTable() {
            const body = document.getElementById('curveCompareBody');
            body.innerHTML = '';
            curves.forEach(c => {
                const tr = document.createElement('tr');

                const swatchTd = document.createElement('td');
                swatchTd.innerHTML = `<span style="display:inline-block;width:14px;height:14px;border-radius:3px;background:${c.color}"></span>`;
                tr.appendChild(swatchTd);

                const labelTd = document.createElement('td');
                labelTd.className = c.isDesign ? 'fw-semibold' : '';
                labelTd.textContent = c.label;
                tr.appendChild(labelTd);

                const angleTd = document.createElement('td');
                angleTd.textContent = c.angle + '°';
                tr.appendChild(angleTd);

                const rpmTd = document.createElement('td');
                rpmTd.textContent = c.rpm + ' RPM';
                tr.appendChild(rpmTd);

                const pinTd = document.createElement('td');
                if (c.isDesign) {
                    pinTd.innerHTML = `<span class="text-muted small">—</span>`;
                } else {
                    const pinBtn = document.createElement('button');
                    pinBtn.type = 'button';
                    pinBtn.className = 'btn btn-sm ' + (c.pinned ? 'btn-primary' : 'btn-outline-secondary');
                    pinBtn.innerHTML = c.pinned ? '📌' : 'Pin';
                    pinBtn.title = c.pinned ? 'Unpin this curve' : 'Pin this curve (keeps it through Regenerate/Reset)';
                    pinBtn.addEventListener('click', () => togglePin(c.id));
                    pinTd.appendChild(pinBtn);
                }
                tr.appendChild(pinTd);

                const removeTd = document.createElement('td');
                if (!c.isDesign) {
                    const rmBtn = document.createElement('button');
                    rmBtn.type = 'button';
                    rmBtn.className = 'btn btn-sm btn-outline-danger';
                    rmBtn.innerHTML = '❌';
                    rmBtn.title = 'Remove this curve';
                    rmBtn.addEventListener('click', () => removeCurve(c.id));
                    removeTd.appendChild(rmBtn);
                }
                tr.appendChild(removeTd);

                body.appendChild(tr);
            });

            document.getElementById('curveCountLabel').textContent = `${curves.length} / ${MAX_CURVES} curves`;

            // Explicit "Pin Curve" button is only actionable when there's an
            // unpinned, non-design curve currently on the chart to pin.
            const pinnable = curves.some(c => !c.isDesign && !c.pinned);
            const btnPin = document.getElementById('btnPinCurve');
            btnPin.disabled = !pinnable;
        }

        function togglePin(id) {
            const c = curves.find(x => x.id === id);
            if (!c || c.isDesign) return;
            c.pinned = !c.pinned;
            c.temporary = false;
            renderTable();
        }

        function removeCurve(id) {
            const c = curves.find(x => x.id === id);
            if (!c || c.isDesign) return;
            curves = curves.filter(x => x.id !== id);
            releaseColor(c.color);
            render();
        }

        function addCurve(newCurveData, angle, rpm, label) {
            // Replace the current temporary (unpinned, non-design) curve if one exists,
            // otherwise just append — this is what makes "change slider, Regenerate" swap
            // only the latest unpinned curve while pinned ones stay put.
            const tempIndex = curves.findIndex(c => c.temporary && !c.pinned && !c.isDesign);
            if (tempIndex !== -1) {
                releaseColor(curves[tempIndex].color);
                curves.splice(tempIndex, 1);
            }

            let limitHit = false;
            if (curves.length >= MAX_CURVES) {
                const evictIndex = curves.findIndex(c => !c.pinned && !c.isDesign);
                if (evictIndex !== -1) {
                    releaseColor(curves[evictIndex].color);
                    curves.splice(evictIndex, 1);
                    limitHit = true;
                } else {
                    document.getElementById('curveLimitAlert').textContent =
                        'Maximum of 10 comparison curves reached and all are pinned — unpin one to add another.';
                    document.getElementById('curveLimitAlert').classList.remove('d-none');
                    return;
                }
            }

            const color = nextColor();
            curves.push({
                id: 'curve-' + Date.now(),
               label: label,
                angle, rpm, color,
                pinned: false,
                isDesign: false,
                temporary: true,
                q: newCurveData.q, dp: newCurveData.dp, eta: newCurveData.eta, kw: newCurveData.kw
            });

            const limitAlert = document.getElementById('curveLimitAlert');
            if (limitHit) {
                limitAlert.textContent = 'Maximum of 10 comparison curves reached — oldest unpinned curve was removed automatically.';
                limitAlert.classList.remove('d-none');
            } else {
                limitAlert.classList.add('d-none');
            }

            render();
        }

        // ── Slider event listeners ────────────────────────────────────
        const sliderAngle  = document.getElementById('sliderAngle');
        const sliderRpm    = document.getElementById('sliderRpm');
        const labelAngle   = document.getElementById('labelAngle');
        const labelRpm     = document.getElementById('labelRpm');
        const displayAngle = document.getElementById('displayAngle');
        const displayRpm   = document.getElementById('displayRpm');
        const displayStatus= document.getElementById('displayStatus');

        // Update labels live as slider moves
        sliderAngle.addEventListener('input', function () {
            const val = parseFloat(this.value);
            labelAngle.textContent   = val + ' °';
            displayAngle.textContent = val + ' °';
        });

        sliderRpm.addEventListener('input', function () {
            const val = parseInt(this.value);
            labelRpm.textContent   = val + ' RPM';
            displayRpm.textContent = val + ' RPM';
        });

        // ── Regenerate button ─────────────────────────────────────────
        document.getElementById('btnGenCurve')
                .addEventListener('click', async () => {
            const angle = parseFloat(sliderAngle.value);
            const rpm   = parseInt(sliderRpm.value);

            displayStatus.textContent = 'Generating...';
            displayStatus.className   = 'fw-bold text-warning fs-5';

            try {
                const token = document.querySelector(
                    'input[name=__RequestVerificationToken]')?.value || '';

                const resp = await fetch(
                    `/Results/GenerateCurve?resultId=${resultId}` +
                    `&bladeAngleDeg=${angle}&speedRpm=${rpm}`,
                    {
                        method: 'POST',
                        headers: { 'RequestVerificationToken': token }
                    }
                );

                if (resp.ok) {
                           const d = await resp.json();

        addCurve(
        {
            q: d.baseline.q,
            dp: d.baseline.dp,
            eta: d.baseline.eta,
            kw: d.baseline.kw
        },
        angle,
        rpm);

        addCurve(
        {
            q: d.corrected.q,
            dp: d.corrected.dp,
            eta: d.corrected.eta,
            kw: d.corrected.kw
        },
        angle,
        rpm);


                    displayStatus.textContent = '✓ Updated';
                    displayStatus.className   =
                        'fw-bold text-success fs-5';
                } else {
                    displayStatus.textContent = '✗ Error';
                    displayStatus.className   =
                        'fw-bold text-danger fs-5';
                }
            } catch (e) {
                displayStatus.textContent = '✗ Failed';
                displayStatus.className   = 'fw-bold text-danger fs-5';
            }
        });

        // ── Pin Curve button — pins the most recently added unpinned curve ──
        document.getElementById('btnPinCurve').addEventListener('click', () => {
            // Pin the latest unpinned, non-design curve (i.e. whatever is
            // currently the "temporary" one from the last Regenerate).
            const target = [...curves].reverse().find(c => !c.isDesign && !c.pinned);
            if (!target) return;
            target.pinned = true;
            target.temporary = false;
            renderTable();
        });

        // ── Reset to design point button ──────────────────────────────
        document.getElementById('btnResetCurve')
                .addEventListener('click', () => {
            sliderAngle.value        = designAngle;
            sliderRpm.value          = designRpm;
            labelAngle.textContent   = designAngle + ' °';
            labelRpm.textContent     = designRpm + ' RPM';
            displayAngle.textContent = designAngle + ' °';
            displayRpm.textContent   = designRpm + ' RPM';

            // Remove every curve except the original design curve (pinned or not)
            curves.filter(c => !c.isDesign).forEach(c => releaseColor(c.color));
            curves = curves.filter(c => c.isDesign);

            document.getElementById('curveLimitAlert').classList.add('d-none');

            render();

            displayStatus.textContent = 'Design Point';
            displayStatus.className   = 'fw-bold text-primary fs-5';
        });

        // ── Initial render ──────────────────────────────────────────────
        render(); // also sets #btnPinCurve to disabled since only the design curve exists yet

        // ── Download PDF Summary — captures charts exactly as shown ────
        document.getElementById('btnDownloadPdf').addEventListener('click', async (e) => {
            e.preventDefault();
            const link = e.currentTarget;
            const originalHtml = link.innerHTML;
            link.innerHTML = '<i class="bi bi-hourglass-split me-2"></i>Generating PDF...';

            try {
                const qdpImage = chartQdp.canvas.toDataURL('image/png', 1.0);
                const etaImage = chartEta.canvas.toDataURL('image/png', 1.0);

                // Only send the curve comparison rows if more than the design
                // curve is on screen — otherwise there's nothing to compare.
                const curvePayload = curves.length > 1
                    ? curves.map(c => ({
                        label: c.label,
                        angle: c.angle,
                        rpm: c.rpm,
                        color: c.color,
                        isDesign: c.isDesign
                    }))
                    : [];

                const token = document.querySelector('input[name=__RequestVerificationToken]')?.value || '';

                const resp = await fetch('/Export/PdfWithCharts', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify({
                        resultId: resultId,
                        qdpImageBase64: qdpImage,
                        etaImageBase64: etaImage,
                        curves: curvePayload
                    })
                });

                if (!resp.ok) throw new Error(`Server returned ${resp.status}`);

                const blob = await resp.blob();
                const url = window.URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = `AxialFan_Result_${resultId}.pdf`;
                document.body.appendChild(a);
                a.click();
                a.remove();
                window.URL.revokeObjectURL(url);
            } catch (err) {
                alert('Could not generate PDF: ' + err.message);
            } finally {
                link.innerHTML = originalHtml;
            }
        });
    </script>
}
