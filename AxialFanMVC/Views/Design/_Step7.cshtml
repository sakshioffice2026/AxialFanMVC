@model AxialFanMVC.ViewModels.DesignWizardViewModel

<h2 class="dw-panel-title mb-3 fw-bold" style="color:var(--v2-accent)">Accessories</h2>
<p class="text-muted small mb-3">Select the accessories to include with this fan design.</p>

<div class="row g-3">
    <div class="col-md-6">
        <div class="form-check">
            <input class="form-check-input" type="checkbox" asp-for="AccInletGuard" id="accInletGuard" />
            <label class="form-check-label" for="accInletGuard">Inlet Safety Guard</label>
        </div>
        <div class="form-text ps-4">Prevents contact with rotating blades at the fan inlet.</div>
    </div>
    <div class="col-md-6">
        <div class="form-check">
            <input class="form-check-input" type="checkbox" asp-for="AccOutletGuard" id="accOutletGuard" />
            <label class="form-check-label" for="accOutletGuard">Outlet Safety Guard</label>
        </div>
        <div class="form-text ps-4">Prevents contact with rotating blades at the fan outlet.</div>
    </div>
    <div class="col-md-6">
        <div class="form-check">
            <input class="form-check-input" type="checkbox" asp-for="AccVibrationIsolators" id="accVibrationIsolators" />
            <label class="form-check-label" for="accVibrationIsolators">Vibration Isolators</label>
        </div>
        <div class="form-text ps-4">Isolates fan vibration from the supporting structure.</div>
    </div>
    <div class="col-md-6">
        <div class="form-check">
            <input class="form-check-input" type="checkbox" asp-for="AccFlexibleConnector" id="accFlexibleConnector" />
            <label class="form-check-label" for="accFlexibleConnector">Flexible Duct Connector</label>
        </div>
        <div class="form-text ps-4">Absorbs thermal expansion and misalignment in ductwork.</div>
    </div>
    <div class="col-md-6">
        <div class="form-check">
            <input class="form-check-input" type="checkbox" asp-for="AccSilencer" id="accSilencer" />
            <label class="form-check-label" for="accSilencer">Inlet/Outlet Silencer</label>
        </div>
        <div class="form-text ps-4">Reduces noise at the fan inlet and/or outlet.</div>
    </div>
    <div class="col-md-6">
        <div class="form-check">
            <input class="form-check-input" type="checkbox" asp-for="AccBackdraftDamper" id="accBackdraftDamper" />
            <label class="form-check-label" for="accBackdraftDamper">Backdraft Damper</label>
        </div>
        <div class="form-text ps-4">Prevents reverse airflow when the fan is stopped.</div>
    </div>
</div>

<h2 class="dw-panel-title mb-3 mt-4 fw-bold" style="color:var(--v2-accent)">Notes</h2>
<div class="row g-3">
    <div class="col-12">
        <label asp-for="AccessoryNotes" class="form-label">Accessory Notes</label>
        <textarea asp-for="AccessoryNotes" class="form-control" rows="3" maxlength="1000"
                  placeholder="Any additional accessory requirements, special mounting instructions, or client-specified options..."></textarea>
        <div class="form-text">Optional — free text, up to 1000 characters.</div>
    </div>
</div>
