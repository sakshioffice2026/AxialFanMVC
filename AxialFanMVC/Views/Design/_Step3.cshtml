@model AxialFanMVC.ViewModels.DesignWizardViewModel
@using System.Linq

<h2 class="dw-panel-title mb-3 fw-bold" style="color:var(--v2-accent)">Fan Constraints</h2>
<div class="row g-3">
    <div class="col-md-6">
        <label asp-for="MaxTipDiameterMm" class="form-label">Max Tip Diameter</label>
        <div class="input-group">
            <input asp-for="MaxTipDiameterMm" type="text" class="form-control" />
            <span class="input-group-text">mm</span>
        </div>
    </div>
    <div class="col-md-6">
        <label asp-for="MinEfficiencyPct" class="form-label">Min Required Efficiency</label>
        <div class="input-group">
            <input asp-for="MinEfficiencyPct" type="text" class="form-control" />
            <span class="input-group-text">%</span>
        </div>
    </div>
    <div class="col-md-6">
        <label asp-for="MaxNoiseDbA" class="form-label">Max Noise Level</label>
        <div class="input-group">
            <input asp-for="MaxNoiseDbA" type="text" class="form-control" />
            <span class="input-group-text">dB(A)</span>
        </div>
    </div>
    <div class="col-md-6">
        <label asp-for="MaxMotorPowerKw" class="form-label">Max Motor Power</label>
        <div class="input-group">
            <input asp-for="MaxMotorPowerKw" type="text" class="form-control" />
            <span class="input-group-text">kW</span>
        </div>
    </div>
    <div class="col-md-6">
        <label asp-for="PreferredBladeCount" class="form-label">Preferred Blade Count</label>
        <select asp-for="PreferredBladeCount" class="form-select">
            <option value="6">6</option>
            <option value="8">8</option>
            <option value="10">10</option>
            <option value="12">12</option>
        </select>
    </div>
    <div class="col-md-6">
        <label asp-for="MaxSpeedRpm" class="form-label">Max Speed</label>
        <div class="input-group">
            <input asp-for="MaxSpeedRpm" type="text" class="form-control" />
            <span class="input-group-text">RPM</span>
        </div>
    </div>
</div>

@* ═══════════════════════════════════════════════════════════════════
   AI-Optimized Candidates (NSGA-II + PINN, verified up front)
   Uses the constraints above (already saved to the project's DesignInput
   on a prior "Next") — Optimization/Start reads them straight off the DB,
   so nothing here needs to be posted; it just needs a projectId.
   ═══════════════════════════════════════════════════════════════════ *@
<hr class="my-4" />
<div id="optimizePanel">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="dw-panel-title fw-bold mb-0" style="color:var(--v2-accent)">AI-Optimized Candidates</h2>
        <button type="button" id="btnRunOptimize" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-stars me-1"></i>Generate 3 Candidates
        </button>
    </div>

    @* ── Process explainer strip ──────────────────────────────────────
       Plain-language story of what happens, no ML jargon. Cards pick up
       .step-active / .step-done as the real job progresses (see script
       below) — this isn't just decorative, it reflects actual job state. *@
    <div class="opt-explainer row g-2 mb-3">
        <div class="col-6 col-md-3">
            <div class="opt-step-card step-done" data-step="requirements">
                <div class="opt-step-icon"><i class="bi bi-sliders"></i></div>
                <div class="opt-step-title">Your requirements</div>
                <div class="opt-step-sub">Airflow, pressure and limits you already entered</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="opt-step-card" data-step="search">
                <div class="opt-step-icon"><i class="bi bi-lightning-charge"></i></div>
                <div class="opt-step-title">Instant search</div>
                <div class="opt-step-sub">Tries thousands of designs in seconds</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="opt-step-card" data-step="options">
                <div class="opt-step-icon"><i class="bi bi-layers"></i></div>
                <div class="opt-step-title">Best options</div>
                <div class="opt-step-sub">Narrows it down to 3 strong choices</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="opt-step-card" data-step="check">
                <div class="opt-step-icon"><i class="bi bi-shield-check"></i></div>
                <div class="opt-step-title">Engineering check</div>
                <div class="opt-step-sub">Confirmed with your real calculations, not just a guess</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="opt-step-card" data-step="design">
                <div class="opt-step-icon"><i class="bi bi-check-circle"></i></div>
                <div class="opt-step-title">Your design</div>
                <div class="opt-step-sub">Fills in Step 4 automatically</div>
            </div>
        </div>
    </div>

    <div id="optimizeLoading" class="text-center text-muted small py-3" style="display:none">
        <div class="spinner-border spinner-border-sm me-2"></div>
        <span id="optimizeStatusMsg">Queuing optimization job…</span>
    </div>

    <div id="optimizeError" class="alert alert-danger small" style="display:none"></div>

    <div id="candidateRow" class="row g-3" style="display:none"></div>
</div>

<style>
    .opt-step-card {
        background: var(--v2-bg);
        border: 1px solid var(--v2-border);
        border-radius: .5rem;
        padding: .875rem .9rem;
        height: 100%;
        transition: border-color .2s ease, background .2s ease;
    }

    .opt-step-icon {
        color: var(--v2-accent);
        font-size: 1.15rem;
        opacity: .55;
        margin-bottom: .35rem;
    }

    .opt-step-title {
        font-size: .8125rem;
        font-weight: 700;
        color: #22302e;
        margin-bottom: .15rem;
    }

    .opt-step-sub {
        font-size: .75rem;
        color: #8a938f;
        line-height: 1.3;
    }

    /* Currently in progress — mirrors the "Engineering check" emphasis in the mockup */
    .opt-step-card.step-active {
        border-color: var(--v2-accent);
        background: color-mix(in srgb, var(--v2-accent) 6%, var(--v2-bg));
    }

    .opt-step-card.step-active .opt-step-icon {
        opacity: 1;
    }

    /* Already completed for this run */
    .opt-step-card.step-done .opt-step-icon {
        opacity: 1;
        color: #2f9e5c;
    }

    .opt-step-card.step-done .opt-step-title {
        color: #2f9e5c;
    }
</style>

<template id="candidateCardTpl">
    <div class="col-md-4">
        <div class="card h-100 candidate-card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <h5 class="card-title mb-0 cand-label"></h5>
                    <span class="badge cand-badge"></span>
                </div>
                <table class="table table-sm mb-2 small">
                    <tbody>
                        <tr><td class="text-muted">Efficiency</td><td class="text-end cand-eff"></td></tr>
                        <tr><td class="text-muted">Noise</td><td class="text-end cand-noise"></td></tr>
                        <tr><td class="text-muted">Est. Cost</td><td class="text-end cand-cost"></td></tr>
                        <tr><td class="text-muted">Safety Factor</td><td class="text-end cand-sf"></td></tr>
                        <tr><td class="text-muted">Tip Ø / Hub Ratio</td><td class="text-end cand-geom"></td></tr>
                        <tr><td class="text-muted">Blade Profile</td><td class="text-end cand-profile"></td></tr>
                    </tbody>
                </table>
                <ul class="cand-warnings small text-warning ps-3 mb-2"></ul>
                <button type="button" class="btn btn-primary btn-sm w-100 cand-select-btn">Use this candidate</button>
            </div>
        </div>
    </div>
</template>

@* Designation -> BladeProfileId lookup, so a selected candidate's blade
   profile string (e.g. "NACA-4412") can be resolved to the FK Step 4 needs.
   Model.BladeProfiles is already loaded for every step by DesignController. *@
<script id="bladeProfileLookup" type="application/json">
    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        (Model.BladeProfiles ?? new List<AxialFanMVC.Database.BladeProfile>())
            .Select(p => new { id = p.Id, name = p.Name })))
</script>

<script>
    (function () {
        const projectId = @Model.ProjectId;
        const profileLookup = JSON.parse(document.getElementById('bladeProfileLookup').textContent || '[]');
        let pollHandle = null;

        function token() {
            return document.querySelector('input[name=__RequestVerificationToken]')?.value || '';
        }

        function setStepState(step, state) {
            const card = document.querySelector(`.opt-step-card[data-step="${step}"]`);
            if (!card) return;
            card.classList.remove('step-active', 'step-done');
            if (state) card.classList.add(state);
        }

        function resetExplainer() {
            setStepState('requirements', 'step-done'); // always true — collected in steps 1–3
            setStepState('search', null);
            setStepState('options', null);
            setStepState('check', null);
            setStepState('design', null);
        }

        function badgeFor(candidate) {
            if (!candidate.verified) return { text: 'Not verified', cls: 'bg-danger' };
            if (candidate.verification_warnings && candidate.verification_warnings.length > 0)
                return { text: 'Verified — warnings', cls: 'bg-warning text-dark' };
            return { text: 'Verified', cls: 'bg-success' };
        }

        function resolveProfileId(designation) {
            if (!designation) return null;
            const match = profileLookup.find(p => p.name.toLowerCase() === designation.toLowerCase());
            return match ? match.id : null;
        }

        function renderCandidates(candidates) {
            const row = document.getElementById('candidateRow');
            const tpl = document.getElementById('candidateCardTpl');
            row.innerHTML = '';

            candidates.forEach(function (c) {
                const node = tpl.content.cloneNode(true);
                node.querySelector('.cand-label').textContent = c.label || 'Candidate';

                const badge = badgeFor(c);
                const badgeEl = node.querySelector('.cand-badge');
                badgeEl.textContent = badge.text;
                badgeEl.classList.add(...badge.cls.split(' '));

                const eff = c.verified ? c.verified_efficiency_pct : c.predicted_efficiency_pct;
                const noise = c.verified ? c.verified_noise_dba : c.predicted_noise_dba;
                const cost = c.verified ? c.verified_cost_total : c.predicted_cost_total;
                const sf = c.verified ? c.verified_safety_factor : c.predicted_safety_factor;

                node.querySelector('.cand-eff').textContent = eff.toFixed(1) + ' %' + (c.verified ? '' : ' (predicted)');
                node.querySelector('.cand-noise').textContent = noise.toFixed(1) + ' dB(A)';
                node.querySelector('.cand-cost').textContent = cost.toLocaleString(undefined, { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });
                node.querySelector('.cand-sf').textContent = sf.toFixed(2);
                node.querySelector('.cand-geom').textContent = c.tip_diameter_mm.toFixed(0) + ' mm / ' + c.hub_ratio.toFixed(2);
                node.querySelector('.cand-profile').textContent = c.blade_profile || '—';

                const warningsEl = node.querySelector('.cand-warnings');
                (c.verification_warnings || []).forEach(function (w) {
                    const li = document.createElement('li');
                    li.textContent = w;
                    warningsEl.appendChild(li);
                });

                const selectBtn = node.querySelector('.cand-select-btn');
                if (!c.verified) {
                    selectBtn.disabled = true;
                    selectBtn.textContent = 'Not eligible (failed verification)';
                } else {
                    selectBtn.addEventListener('click', function () { applyCandidate(c, node); });
                }

                row.appendChild(node);
            });

            row.style.display = 'flex';
        }

        function applyCandidate(c, node) {
            document.querySelectorAll('.candidate-card').forEach(el => el.classList.remove('border-primary', 'border-3'));
            // node is a DocumentFragment reference from cloning, so re-query the live card by label instead
            document.querySelectorAll('.candidate-card').forEach(function (card) {
                if (card.querySelector('.cand-label').textContent === (c.label || 'Candidate')) {
                    card.classList.add('border-primary', 'border-3');
                }
            });

            setField('TipDiameterMm', c.tip_diameter_mm);
            setField('HubRatio', c.hub_ratio);
            setField('BladeAngleDeg', c.blade_angle_deg);
            setField('BladeCount', c.blade_count);
            setField('TargetEfficiencyPct', c.verified ? c.verified_efficiency_pct : c.predicted_efficiency_pct);

            const profileId = resolveProfileId(c.blade_profile);
            if (profileId !== null) {
                setField('BladeProfileId', profileId);
            }

            setStepState('options', 'step-done');
            setStepState('design', 'step-done');

            // Purely a UI hint for Step 4's banner — the actual values above
            // already round-trip through the normal hidden-field/TempData flow
            // regardless of whether this succeeds.
            try {
                sessionStorage.setItem('optimizeAppliedCandidate_' + projectId, JSON.stringify({
                    label: c.label,
                    verifiedEfficiencyPct: c.verified_efficiency_pct,
                    profileResolved: profileId !== null,
                    profileDesignation: c.blade_profile
                }));
            } catch (e) { /* sessionStorage unavailable — non-critical */ }
        }

        function setField(id, value) {
            const el = document.getElementById(id);
            if (el) el.value = value;
        }

        function showError(msg) {
            document.getElementById('optimizeLoading').style.display = 'none';
            const errEl = document.getElementById('optimizeError');
            errEl.textContent = msg;
            errEl.style.display = 'block';
        }

        function poll(jobId) {
            // NOTE: the app's default route is "{controller}/{action}/{id?}" — Status
            // takes "jobId", not "id", so it must be passed as a query string, not a
            // path segment, or model binding silently receives 0/null.
            fetch(`/Optimization/Status?jobId=${jobId}`, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                .then(res => { if (!res.ok) throw new Error('Status check failed (HTTP ' + res.status + ')'); return res.json(); })
                .then(function (data) {
                    document.getElementById('optimizeStatusMsg').textContent = 'Status: ' + data.status;

                    if (data.status === 'Failed') {
                        clearInterval(pollHandle);
                        setStepState('search', null);
                        showError(data.errorMessage || 'Optimization failed.');
                        return;
                    }
                    if (data.status === 'Completed') {
                        clearInterval(pollHandle);
                        document.getElementById('optimizeLoading').style.display = 'none';
                        // Search + the engine-verification pass both finish together
                        // server-side before Completed is ever set — see
                        // OptimizationBackgroundService/CandidateVerificationService —
                        // so both light up as done at the same moment here.
                        setStepState('search', 'step-done');
                        setStepState('check', 'step-done');
                        setStepState('options', 'step-active');
                        renderCandidates(data.candidates || []);
                    }
                })
                .catch(function (err) {
                    clearInterval(pollHandle);
                    setStepState('search', null);
                    showError('Could not retrieve optimization status: ' + err.message);
                });
        }

        document.getElementById('btnRunOptimize').addEventListener('click', function () {
            const btn = this;
            btn.disabled = true;
            document.getElementById('optimizeError').style.display = 'none';
            document.getElementById('candidateRow').style.display = 'none';
            document.getElementById('optimizeLoading').style.display = 'block';
            document.getElementById('optimizeStatusMsg').textContent = 'Queuing optimization job…';
            resetExplainer();
            setStepState('search', 'step-active');

            // Same routing note as poll() above — projectId must be a query param.
            fetch(`/Optimization/Start?projectId=${projectId}`, {
                method: 'POST',
                headers: { 'RequestVerificationToken': token() }
            })
            .then(function (res) {
                if (!res.ok) return res.text().then(t => { throw new Error(t || ('HTTP ' + res.status)); });
                return res.json();
            })
            .then(function (data) {
                pollHandle = setInterval(function () { poll(data.jobId); }, 2000);
                poll(data.jobId);
            })
            .catch(function (err) {
                setStepState('search', null);
                showError('Could not start optimization: ' + err.message);
            })
            .finally(function () { btn.disabled = false; });
        });

        resetExplainer();
    })();
</script>
