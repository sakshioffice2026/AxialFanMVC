@{
    ViewData["Title"] = "New Axial Fan Design";
    Layout = "_LayoutV2";
}

<style>
    .wiz-stepper {
        display: flex;
        align-items: center;
        overflow-x: auto;
        gap: 0.25rem;
        padding: 0.75rem 1rem;
        background: #fff;
        border: 1px solid var(--v2-border, #e2e6e4);
        border-radius: 0.5rem;
    }

    .wiz-step {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        white-space: nowrap;
        color: #8a9694;
        font-size: 0.85rem;
        padding: 0.25rem 0.6rem;
    }

        .wiz-step .num {
            width: 22px;
            height: 22px;
            border-radius: 50%;
            border: 1px solid #cfd6d5;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 0.75rem;
            flex-shrink: 0;
        }

        .wiz-step.active {
            color: var(--v2-accent, #3E7C8C);
            font-weight: 600;
        }

            .wiz-step.active .num {
                background: var(--v2-accent, #3E7C8C);
                border-color: var(--v2-accent, #3E7C8C);
                color: #fff;
            }

        .wiz-step.done .num {
            background: #2e7d32;
            border-color: #2e7d32;
            color: #fff;
        }

    .wiz-step-sep {
        flex-grow: 1;
        height: 1px;
        background: #e2e6e4;
        min-width: 12px;
    }

    .wiz-card {
        background: #fff;
        border: 1px solid var(--v2-border, #e2e6e4);
        border-radius: 0.5rem;
        padding: 1.25rem;
    }

    .wiz-section-title {
        color: var(--v2-accent, #3E7C8C);
        font-weight: 600;
        margin-bottom: 1rem;
    }

    .wiz-subheading {
        font-weight: 600;
        font-size: 0.85rem;
        color: #55605e;
        margin-bottom: 0.75rem;
    }

    .wiz-summary-row {
        display: flex;
        justify-content: space-between;
        padding: 0.4rem 0;
        border-bottom: 1px solid #f0f2f1;
        font-size: 0.875rem;
    }

        .wiz-summary-row:last-child {
            border-bottom: none;
        }

    .wiz-summary-label {
        color: #8a9694;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0 fw-bold">New Axial Fan Design</h4>
    <div class="d-flex gap-2">
        <button class="v2-back-btn" type="button" disabled><i class="bi bi-arrow-left"></i> Back</button>
        <button class="btn btn-primary btn-sm" type="button" disabled>Next <i class="bi bi-arrow-right"></i></button>
    </div>
</div>

<div class="wiz-stepper mb-3">
    @{
        var steps = new (int Num, string Label, string State)[]
        {
    (1, "Project Info", "done"), (2, "Air Input", "done"), (3, "Fan Constraints", "done"),
    (4, "Design & Results", "done"), (5, "Performance", "done"), (6, "Motor", "active"),
    (7, "Accessories", ""), (8, "Output & Save", "")
        };
    }
    @for (int i = 0; i < steps.Length; i++)
    {
        var s = steps[i];
        <div class="wiz-step @s.State">
            <span class="num">@(s.State == "done" ? "✓" : s.Num.ToString())</span>
            <span>@s.Label</span>
        </div>
        if (i < steps.Length - 1)
        {
            <div class="wiz-step-sep"></div>
        }
    }
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <div class="wiz-card">
            <div class="wiz-section-title">Motor</div>

            <div class="wiz-subheading">Motor Specification</div>
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label small">Motor Power</label>
                    <div class="input-group input-group-sm">
                        <input type="text" class="form-control" value="18.5" disabled />
                        <span class="input-group-text">kW</span>
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Motor Type</label>
                    <select class="form-select form-select-sm" disabled><option>TEFC (IE3)</option></select>
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Voltage</label>
                    <select class="form-select form-select-sm" disabled><option>415V</option></select>
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Phase</label>
                    <select class="form-select form-select-sm" disabled><option>3-Phase</option></select>
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Poles / Sync. Speed</label>
                    <select class="form-select form-select-sm" disabled><option>4-Pole (1500 RPM)</option></select>
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Enclosure Class</label>
                    <select class="form-select form-select-sm" disabled><option>IP55</option></select>
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Insulation Class</label>
                    <select class="form-select form-select-sm" disabled><option>Class F</option></select>
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Starter Type</label>
                    <select class="form-select form-select-sm" disabled><option>Star-Delta</option></select>
                </div>
            </div>

            <div class="wiz-subheading">Drive Configuration</div>
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label small">Drive Type</label>
                    <select class="form-select form-select-sm" disabled><option>Direct Drive</option></select>
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Coupling Type</label>
                    <select class="form-select form-select-sm" disabled><option>Flexible Coupling</option></select>
                </div>
            </div>

            <div class="d-flex justify-content-between">
                <button class="btn btn-outline-secondary btn-sm" disabled><i class="bi bi-arrow-counterclockwise me-1"></i>Reset</button>
                <button class="btn btn-primary btn-sm" disabled>Next <i class="bi bi-arrow-right"></i></button>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="wiz-card">
            <div class="wiz-section-title">Motor Summary</div>
            <div class="wiz-summary-row"><span class="wiz-summary-label">Power</span><span>18.5 kW</span></div>
            <div class="wiz-summary-row"><span class="wiz-summary-label">Type</span><span>TEFC (IE3)</span></div>
            <div class="wiz-summary-row"><span class="wiz-summary-label">Voltage / Phase</span><span>415V / 3-Ph</span></div>
            <div class="wiz-summary-row"><span class="wiz-summary-label">Speed</span><span>1500 RPM</span></div>
            <div class="wiz-summary-row"><span class="wiz-summary-label">Drive</span><span>Direct Drive</span></div>
        </div>
    </div>
</div>