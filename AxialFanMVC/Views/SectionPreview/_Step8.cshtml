<h2 class="dw-panel-title mb-3 fw-bold" style="color:var(--v2-accent)">Output &amp; Save</h2>
<div class="row g-3">
    <div class="col-md-6">
        <label class="form-label">Design / Revision Name</label>
        <input type="text" class="form-control" asp-action="Post" value="Cement Plant – ID Fan Rev A">
    </div>
    <div class="col-md-6">
        <label class="form-label">Revision Notes</label>
        <input type="text" class="form-control" placeholder="e.g. Increased tip diameter per client review">
    </div>
</div>
<div class="mt-3">
    <div class="text-uppercase small fw-bold text-muted mb-2" style="letter-spacing:.04em;">Export Options</div>
    <div class="form-check">
        <input type="checkbox" class="form-check-input" id="outPdf" checked>
        <label class="form-check-label" for="outPdf">PDF Design Report</label>
    </div>
    <div class="form-check">
        <input type="checkbox" class="form-check-input" id="outDxf" checked>
        <label class="form-check-label" for="outDxf">DXF Drawings</label>
    </div>
    <div class="form-check">
        <input type="checkbox" class="form-check-input" id="outCsv">
        <label class="form-check-label" for="outCsv">CSV Performance Data</label>
    </div>
</div>
