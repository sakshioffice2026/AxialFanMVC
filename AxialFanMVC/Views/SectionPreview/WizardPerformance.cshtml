@{
    ViewData["Title"] = "New Axial Fan Design";
    Layout = "_LayoutV2";
}

<style>
    .wiz-stepper {
        display: flex;
        align-items: center;
        overflow-x: auto;
        gap: 0.25rem;
        padding: 0.75rem 1rem;
        background: #fff;
        border: 1px solid var(--v2-border, #e2e6e4);
        border-radius: 0.5rem;
    }

    .wiz-step {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        white-space: nowrap;
        color: #8a9694;
        font-size: 0.85rem;
        padding: 0.25rem 0.6rem;
    }

        .wiz-step .num {
            width: 22px;
            height: 22px;
            border-radius: 50%;
            border: 1px solid #cfd6d5;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 0.75rem;
            flex-shrink: 0;
        }

        .wiz-step.active {
            color: var(--v2-accent, #3E7C8C);
            font-weight: 600;
        }

            .wiz-step.active .num {
                background: var(--v2-accent, #3E7C8C);
                border-color: var(--v2-accent, #3E7C8C);
                color: #fff;
            }

        .wiz-step.done .num {
            background: #2e7d32;
            border-color: #2e7d32;
            color: #fff;
        }

    .wiz-step-sep {
        flex-grow: 1;
        height: 1px;
        background: #e2e6e4;
        min-width: 12px;
    }

    .wiz-card {
        background: #fff;
        border: 1px solid var(--v2-border, #e2e6e4);
        border-radius: 0.5rem;
        padding: 1.25rem;
    }

    .wiz-section-title {
        color: var(--v2-accent, #3E7C8C);
        font-weight: 600;
        margin-bottom: 1rem;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0 fw-bold">New Axial Fan Design</h4>
    <div class="d-flex gap-2">
        <button class="v2-back-btn" type="button" disabled><i class="bi bi-arrow-left"></i> Back</button>
        <button class="btn btn-primary btn-sm" type="button" disabled>Next <i class="bi bi-arrow-right"></i></button>
    </div>
</div>

<div class="wiz-stepper mb-3">
    @{
        var steps = new (int Num, string Label, string State)[]
        {
    (1, "Project Info", "done"), (2, "Air Input", "done"), (3, "Fan Constraints", "done"),
    (4, "Design & Results", "done"), (5, "Performance", "active"), (6, "Motor", ""),
    (7, "Accessories", ""), (8, "Output & Save", "")
        };
    }
    @for (int i = 0; i < steps.Length; i++)
    {
        var s = steps[i];
        <div class="wiz-step @s.State">
            <span class="num">@(s.State == "done" ? "✓" : s.Num.ToString())</span>
            <span>@s.Label</span>
        </div>
        if (i < steps.Length - 1)
        {
            <div class="wiz-step-sep"></div>
        }
    }
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <div class="wiz-card mb-3">
            <div class="wiz-section-title">Performance Curves</div>
            <canvas id="perfChart" height="220"></canvas>
        </div>
        <div class="wiz-card">
            <div class="wiz-section-title">Curve Data Points</div>
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead><tr><th>Flow (m³/s)</th><th>Static Pressure (Pa)</th><th>Efficiency (%)</th><th>Power (kW)</th></tr></thead>
                    <tbody>
                        <tr><td>10</td><td>820</td><td>62.1</td><td>16.5</td></tr>
                        <tr><td>15</td><td>780</td><td>71.4</td><td>17.1</td></tr>
                        <tr><td>20</td><td>720</td><td>76.8</td><td>17.9</td></tr>
                        <tr class="table-active fw-semibold"><td>25</td><td>650</td><td>78.2</td><td>18.4</td></tr>
                        <tr><td>30</td><td>560</td><td>74.6</td><td>19.2</td></tr>
                    </tbody>
                </table>
            </div>
            <div class="small text-muted mt-2">Highlighted row = current design operating point.</div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="wiz-card mb-3">
            <div class="wiz-section-title">Operating Point</div>
            <div class="wiz-summary-row d-flex justify-content-between py-1 border-bottom"><span class="text-muted">Flow Rate</span><span>25.0 m³/s</span></div>
            <div class="wiz-summary-row d-flex justify-content-between py-1 border-bottom"><span class="text-muted">Static Pressure</span><span>650 Pa</span></div>
            <div class="wiz-summary-row d-flex justify-content-between py-1 border-bottom"><span class="text-muted">Efficiency</span><span>78.2%</span></div>
            <div class="wiz-summary-row d-flex justify-content-between py-1"><span class="text-muted">Power</span><span>18.4 kW</span></div>
        </div>
        <div class="wiz-card" style="background:#fff8ea; border-color:#f5e3b3;">
            <div class="fw-semibold mb-2"><i class="bi bi-lightbulb-fill text-warning me-1"></i>Tips</div>
            <ul class="small mb-0 ps-3">
                <li>Operate near the peak efficiency point for lowest running cost.</li>
                <li>A flat curve near the operating point is more tolerant of system changes.</li>
            </ul>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between mt-3">
    <button class="btn btn-outline-secondary btn-sm" disabled><i class="bi bi-arrow-counterclockwise me-1"></i>Reset</button>
    <button class="btn btn-primary btn-sm" disabled>Next <i class="bi bi-arrow-right"></i></button>
</div>

@section Scripts {
    <script>
        new Chart(document.getElementById('perfChart'), {
            type: 'line',
            data: {
                labels: [10, 15, 20, 25, 30],
                datasets: [
                    { label: 'Static Pressure (Pa)', data: [820, 780, 720, 650, 560], borderColor: '#3E7C8C', backgroundColor: 'transparent', yAxisID: 'y' },
                    { label: 'Efficiency (%)', data: [62.1, 71.4, 76.8, 78.2, 74.6], borderColor: '#B8763F', backgroundColor: 'transparent', yAxisID: 'y1' }
                ]
            },
            options: {
                scales: {
                    y: { type: 'linear', position: 'left', title: { display: true, text: 'Pressure (Pa)' } },
                    y1: { type: 'linear', position: 'right', title: { display: true, text: 'Efficiency (%)' }, grid: { drawOnChartArea: false } }
                }
            }
        });
    </script>
}