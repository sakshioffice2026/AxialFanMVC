<h2 class="dw-panel-title mb-3 fw-bold" style="color:var(--v2-accent)">Motor</h2>
<div class="row g-3">
    <div class="col-md-6">
        <label class="form-label">Motor Type</label>
        <select class="form-select">
            <option selected>3-Phase Induction (TEFC)</option>
            <option>3-Phase Induction (ODP)</option>
            <option>Single-Phase</option>
        </select>
    </div>
    <div class="col-md-6">
        <label class="form-label">Rated Power</label>
        <div class="input-group">
            <input type="text" class="form-control" value="15">
            <span class="input-group-text">kW</span>
        </div>
    </div>
    <div class="col-md-6">
        <label class="form-label">Poles</label>
        <select class="form-select">
            <option>2</option><option>4</option><option selected>6</option><option>8</option>
        </select>
    </div>
    <div class="col-md-6">
        <label class="form-label">Voltage</label>
        <select class="form-select">
            <option selected>415 V, 3-Phase</option>
            <option>230 V, 1-Phase</option>
            <option>690 V, 3-Phase</option>
        </select>
    </div>
    <div class="col-md-6">
        <label class="form-label">Insulation Class</label>
        <select class="form-select">
            <option>B</option><option selected>F</option><option>H</option>
        </select>
    </div>
    <div class="col-md-6">
        <label class="form-label">Starting Method</label>
        <select class="form-select">
            <option>Direct on Line</option>
            <option selected>Star-Delta</option>
            <option>VFD</option>
        </select>
    </div>
</div>
