<h2 class="dw-panel-title mb-3 fw-bold" style="color:var(--v2-accent)">Performance</h2>
<canvas id="dwPerfChart" height="140"></canvas>
<table class="table table-sm mt-3">
    <thead>
        <tr><th>Flow (m³/s)</th><th>Static Pressure (Pa)</th><th>Efficiency (%)</th><th>Power (kW)</th></tr>
    </thead>
    <tbody>
        <tr><td>15.0</td><td>820</td><td>72.1</td><td>9.8</td></tr>
        <tr><td>20.0</td><td>740</td><td>78.5</td><td>10.6</td></tr>
        <tr><td>25.0</td><td>650</td><td>81.4</td><td>11.2</td></tr>
        <tr><td>30.0</td><td>540</td><td>77.9</td><td>11.9</td></tr>
        <tr><td>35.0</td><td>410</td><td>70.3</td><td>12.5</td></tr>
    </tbody>
</table>
<script>
    (function () {
        var ctx = document.getElementById('dwPerfChart');
        if (!ctx || typeof Chart === 'undefined') return;
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: ['15.0', '20.0', '25.0', '30.0', '35.0'],
                datasets: [{
                    label: 'Static Pressure (Pa)',
                    data: [820, 740, 650, 540, 410],
                    borderColor: getComputedStyle(document.documentElement).getPropertyValue('--v2-accent').trim() || '#3E7C8C',
                    tension: 0.35,
                    fill: false
                }]
            },
            options: { plugins: { legend: { display: true } }, scales: { y: { beginAtZero: true } } }
        });
    })();
</script>
