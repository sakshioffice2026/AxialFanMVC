@model AxialFanMVC.ViewModels.DesignWizardViewModel
@{
    ViewData["Title"] = "New Axial Fan Design";
    var currentStep = Model.CurrentStep;
    string[] stepNames = {
        "Project Info", "Air Input", "Fan Constraints", "Design & Results",
        "Performance", "Motor", "Accessories", "Output & Save"
    };

    string StepClass(int n) => n < currentStep ? "dw-step done"
                              : n == currentStep ? "dw-step active"
                              : "dw-step";

    string WorkflowStatus(int n) => n < currentStep ? "Completed"
                                   : n == currentStep ? "In Progress"
                                   : "Pending";

    string WorkflowClass(int n) => n < currentStep ? "dw-wf-item completed"
                                  : n == currentStep ? "dw-wf-item active"
                                  : "dw-wf-item pending";
}

<style>
    .dw-stepper { display:flex; flex-wrap:wrap; gap:6px; align-items:center; background:var(--v2-surface); border:1px solid var(--v2-border); border-radius:.5rem; padding:1rem 1.25rem; margin-bottom:1rem; }
    .dw-step { display:flex; align-items:center; gap:8px; font-size:.8125rem; font-weight:600; color:var(--v2-sidebar-text-muted, #9aa5a3); padding:4px 8px; }
    .dw-step .num { width:22px; height:22px; border-radius:50%; border:2px solid #c9cfce; color:#8a938f; font-size:.6875rem; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .dw-step.active { color: var(--v2-accent); }
    .dw-step.active .num { background: var(--v2-accent); border-color: var(--v2-accent); color:#fff; }
    .dw-step.done .num { background:#2f9e5c; border-color:#2f9e5c; color:#fff; }
    .dw-step.done { color:#22302e; }
    .dw-sep { width:18px; height:2px; background:var(--v2-border); }

    .dw-panel { background:var(--v2-surface); border:1px solid var(--v2-border); border-radius:.5rem; padding:1.25rem 1.5rem; margin-bottom:1rem; }
    .dw-panel h2 { font-size:1rem; font-weight:700; color: var(--v2-accent); margin-bottom:1rem; }
    .dw-kv { display:flex; justify-content:space-between; padding:.5rem 0; border-bottom:1px dashed var(--v2-border); font-size:.875rem; }
    .dw-kv:last-child { border-bottom:none; }
    .dw-kv .k { color:#6b7674; }
    .dw-kv .v { font-weight:600; }

    .dw-wf-item { display:flex; align-items:center; justify-content:space-between; padding:.5rem 0; border-bottom:1px solid var(--v2-border); font-size:.8125rem; }
    .dw-wf-item:last-child { border-bottom:none; }
    .dw-wf-item .num { width:18px; height:18px; border-radius:50%; border:1.5px solid #c9cfce; color:#8a938f; font-size:.625rem; display:inline-flex; align-items:center; justify-content:center; margin-right:8px; }
    .dw-wf-item.completed .num { background:#2f9e5c; border-color:#2f9e5c; color:#fff; }
    .dw-wf-item.completed .status { color:#2f9e5c; font-weight:600; }
    .dw-wf-item.active .num { background:var(--v2-accent); border-color:var(--v2-accent); color:#fff; }
    .dw-wf-item.active { color: var(--v2-accent); font-weight:600; }
    .dw-wf-item.pending .status { color:#9aa5a3; }
</style>


<div class="dw-stepper">
    @for (int i = 1; i <= 8; i++)
    {
        <a class="@StepClass(i)" style="text-decoration:none;" asp-action="DesignWizard" asp-route-step="@i">
            <span class="num">@(i < currentStep ? "✓" : i.ToString())</span>@stepNames[i - 1]
        </a>
        if (i < 8) { <span class="dw-sep"></span> }
    }
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <div class="dw-panel">
            @await Html.PartialAsync($"_Step{currentStep}", Model)

            <div class="d-flex justify-content-between mt-3">
                @if (currentStep > 1)
                {
                    <a class="btn btn-outline-secondary" asp-action="DesignWizard" asp-route-step="@(currentStep - 1)">
                        <i class="bi bi-chevron-left"></i> Back
                    </a>
                }
                else
                {
                    <span></span>
                }

                @if (currentStep < 8)
                {
                    <a class="btn btn-primary" asp-action="DesignWizard" asp-route-step="@(currentStep + 1)">
                        Next <i class="bi bi-chevron-right"></i>
                    </a>
                }
                else
                {
                    <button class="btn btn-primary" disabled>Finish (preview only)</button>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        @if (currentStep == 2)
        {
            <div class="dw-panel">
                <h2>Air Properties <small class="text-muted fw-normal">(Calculated)</small></h2>
                <div class="dw-kv"><span class="k">Air Density</span><span class="v">1.18 kg/m³</span></div>
                <div class="dw-kv"><span class="k">Viscosity</span><span class="v">1.91E-05 Pa.s</span></div>
                <div class="dw-kv"><span class="k">Speed of Sound</span><span class="v">354.6 m/s</span></div>
                <div class="dw-kv"><span class="k">Density Correction Factor</span><span class="v">1.03</span></div>
                <div class="dw-kv"><span class="k">Volume Flow @@ Std. Conditions</span><span class="v">24.28 m³/s</span></div>
            </div>
        }

        <div class="dw-panel">
            <h2>Project Summary</h2>
            <div class="dw-kv"><span class="k">Project Name</span><span class="v">Cement Plant – ID Fan</span></div>
            <div class="dw-kv"><span class="k">Client</span><span class="v">ABC Industries Ltd.</span></div>
            <div class="dw-kv"><span class="k">Application</span><span class="v">Industrial Ventilation</span></div>
            <div class="dw-kv"><span class="k">Engineer</span><span class="v">Engineer</span></div>
            <div class="dw-kv"><span class="k">Date</span><span class="v">30 May 2025</span></div>
        </div>
        <div class="dw-panel mb-0">
            <h2>Design Workflow</h2>
            @for (int i = 1; i <= 8; i++)
            {
                <div class="@WorkflowClass(i)">
                    <span><span class="num">@(i < currentStep ? "✓" : i.ToString())</span>@stepNames[i - 1]</span>
                    <span class="status">@WorkflowStatus(i)</span>
                </div>
            }
        </div>
    </div>
</div>

@if (currentStep == 2)
{
    <div class="row g-3 mt-1">
        <div class="col-lg-8">
            <div class="dw-panel mb-0">
                <h2>Typical Axial Fan <small class="text-muted fw-normal">(Reference)</small></h2>

                <div class="d-flex flex-wrap gap-2 mb-3" id="dwRefToggles">
                    <button type="button" class="btn btn-sm btn-primary dw-ref-btn" data-type="long">Long Case</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary dw-ref-btn" data-type="short">Short Case</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary dw-ref-btn" data-type="wall">Wall Mounted</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary dw-ref-btn" data-type="roof">Roof Mounted</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary dw-ref-btn" data-type="plate">Plate Mounted</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary dw-ref-btn" data-type="duct">Duct Mounted</button>
                </div>

                <div class="row g-2">
                    <div class="col-4">
                        <div class="dw-ref-figure">
                            <svg viewBox="0 0 120 120" width="100%" height="100%">
                                <defs>
                                    <radialGradient id="dwHubGrad" cx="35%" cy="30%" r="70%">
                                        <stop offset="0%" stop-color="#8a94a3" />
                                        <stop offset="100%" stop-color="#4b5563" />
                                    </radialGradient>
                                </defs>
                                <circle cx="60" cy="60" r="46" fill="#c8ced8" stroke="#8a94a3" stroke-width="2" />
                                <g fill="#9aa3b1" stroke="#5b6572" stroke-width="1.2">
                                    <g id="dwBlade"><path d="M60 60 L67 20 Q60 12 53 20 Z" /></g>
                                    <use href="#dwBlade" transform="rotate(45 60 60)" />
                                    <use href="#dwBlade" transform="rotate(90 60 60)" />
                                    <use href="#dwBlade" transform="rotate(135 60 60)" />
                                    <use href="#dwBlade" transform="rotate(180 60 60)" />
                                    <use href="#dwBlade" transform="rotate(225 60 60)" />
                                    <use href="#dwBlade" transform="rotate(270 60 60)" />
                                    <use href="#dwBlade" transform="rotate(315 60 60)" />
                                </g>
                                <circle cx="60" cy="60" r="14" fill="url(#dwHubGrad)" stroke="#3a4351" stroke-width="1.5" />
                                <circle cx="60" cy="60" r="4" fill="#2b323d" />
                            </svg>
                        </div>
                    </div>

                    <div class="col-4">
                        <div class="dw-ref-figure" id="dwRefMiddleSlot">

                            <svg class="dw-ref-svg" data-type="long" viewBox="0 0 160 120" width="100%" height="100%">
                                <rect x="30" y="30" width="100" height="60" fill="none" stroke="#5b6572" stroke-width="1.5" />
                                <line x1="45" y1="30" x2="45" y2="90" stroke="#5b6572" stroke-width="1" />
                                <line x1="115" y1="30" x2="115" y2="90" stroke="#5b6572" stroke-width="1" />
                                <line x1="60" y1="34" x2="100" y2="34" stroke="#9aa3b1" stroke-width="6" />
                                <line x1="60" y1="86" x2="100" y2="86" stroke="#9aa3b1" stroke-width="6" />
                                <ellipse cx="80" cy="60" rx="20" ry="26" fill="none" stroke="#5b6572" stroke-width="1" />
                                <line x1="30" y1="18" x2="130" y2="18" stroke="#98a2b3" stroke-width="1" />
                                <text x="76" y="14" font-size="9" fill="#667085">L</text>
                                <text x="12" y="63" font-size="9" fill="#667085">ØA</text>
                                <text x="134" y="63" font-size="9" fill="#667085">ØC</text>
                            </svg>

                            <svg class="dw-ref-svg d-none" data-type="short" viewBox="0 0 160 120" width="100%" height="100%">
                                <rect x="50" y="30" width="60" height="60" fill="none" stroke="#5b6572" stroke-width="1.5" />
                                <line x1="60" y1="30" x2="60" y2="90" stroke="#5b6572" stroke-width="1" />
                                <line x1="100" y1="30" x2="100" y2="90" stroke="#5b6572" stroke-width="1" />
                                <ellipse cx="80" cy="60" rx="16" ry="26" fill="none" stroke="#5b6572" stroke-width="1" />
                                <line x1="50" y1="18" x2="110" y2="18" stroke="#98a2b3" stroke-width="1" />
                                <text x="76" y="14" font-size="9" fill="#667085">L</text>
                                <text x="28" y="63" font-size="9" fill="#667085">ØA</text>
                                <text x="118" y="63" font-size="9" fill="#667085">ØC</text>
                            </svg>

                            <svg class="dw-ref-svg d-none" data-type="wall" viewBox="0 0 160 120" width="100%" height="100%">
                                <defs>
                                    <pattern id="dwHatch" width="6" height="6" patternTransform="rotate(45)" patternUnits="userSpaceOnUse">
                                        <line x1="0" y1="0" x2="0" y2="6" stroke="#98a2b3" stroke-width="1.5" />
                                    </pattern>
                                </defs>
                                <rect x="18" y="20" width="10" height="80" fill="url(#dwHatch)" stroke="#5b6572" stroke-width="1" />
                                <rect x="28" y="35" width="90" height="50" fill="none" stroke="#5b6572" stroke-width="1.5" />
                                <ellipse cx="73" cy="60" rx="18" ry="22" fill="none" stroke="#5b6572" stroke-width="1" />
                                <text x="55" y="112" font-size="9" fill="#667085">Wall Mounted</text>
                            </svg>

                            <svg class="dw-ref-svg d-none" data-type="roof" viewBox="0 0 160 120" width="100%" height="100%">
                                <defs>
                                    <pattern id="dwHatch2" width="6" height="6" patternTransform="rotate(45)" patternUnits="userSpaceOnUse">
                                        <line x1="0" y1="0" x2="0" y2="6" stroke="#98a2b3" stroke-width="1.5" />
                                    </pattern>
                                </defs>
                                <rect x="20" y="90" width="120" height="10" fill="url(#dwHatch2)" stroke="#5b6572" stroke-width="1" />
                                <polygon points="55,90 105,90 95,60 65,60" fill="none" stroke="#5b6572" stroke-width="1.5" />
                                <rect x="55" y="30" width="50" height="30" fill="none" stroke="#5b6572" stroke-width="1.5" />
                                <ellipse cx="80" cy="45" rx="16" ry="12" fill="none" stroke="#5b6572" stroke-width="1" />
                                <text x="55" y="112" font-size="9" fill="#667085">Roof Mounted</text>
                            </svg>

                            <svg class="dw-ref-svg d-none" data-type="plate" viewBox="0 0 160 120" width="100%" height="100%">
                                <rect x="30" y="80" width="100" height="8" fill="#c8ced8" stroke="#5b6572" stroke-width="1.5" />
                                <circle cx="40" cy="84" r="2" fill="#5b6572" />
                                <circle cx="120" cy="84" r="2" fill="#5b6572" />
                                <rect x="50" y="30" width="60" height="50" fill="none" stroke="#5b6572" stroke-width="1.5" />
                                <ellipse cx="80" cy="55" rx="18" ry="20" fill="none" stroke="#5b6572" stroke-width="1" />
                                <text x="55" y="112" font-size="9" fill="#667085">Plate Mounted</text>
                            </svg>

                            <svg class="dw-ref-svg d-none" data-type="duct" viewBox="0 0 160 120" width="100%" height="100%">
                                <rect x="10" y="42" width="30" height="36" fill="none" stroke="#5b6572" stroke-width="1.5" />
                                <rect x="120" y="42" width="30" height="36" fill="none" stroke="#5b6572" stroke-width="1.5" />
                                <rect x="40" y="30" width="80" height="60" fill="none" stroke="#5b6572" stroke-width="1.5" />
                                <ellipse cx="80" cy="60" rx="20" ry="26" fill="none" stroke="#5b6572" stroke-width="1" />
                                <text x="55" y="112" font-size="9" fill="#667085">Duct Mounted</text>
                            </svg>

                        </div>
                    </div>

                    <div class="col-4">
                        <div class="dw-ref-figure">
                            <svg viewBox="0 0 120 120" width="100%" height="100%">
                                <circle cx="60" cy="60" r="48" fill="none" stroke="#5b6572" stroke-width="2" />
                                <circle cx="60" cy="60" r="10" fill="#c8ced8" stroke="#5b6572" stroke-width="1.5" />
                                <g stroke="#5b6572" stroke-width="1">
                                    <line x1="60" y1="12" x2="60" y2="108" />
                                    <line x1="12" y1="60" x2="108" y2="60" />
                                    <line x1="26" y1="26" x2="94" y2="94" />
                                    <line x1="94" y1="26" x2="26" y2="94" />
                                </g>
                            </svg>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <style>
        .dw-ref-figure {
            border: 1px solid var(--v2-border);
            border-radius: 6px;
            background: #fafbfc;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 8px;
            height: 150px;
        }
    </style>

    <script>
        (function () {
            document.querySelectorAll('.dw-ref-btn').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    document.querySelectorAll('.dw-ref-btn').forEach(function (b) {
                        b.classList.remove('btn-primary');
                        b.classList.add('btn-outline-secondary');
                    });
                    btn.classList.remove('btn-outline-secondary');
                    btn.classList.add('btn-primary');

                    var type = btn.getAttribute('data-type');
                    document.querySelectorAll('.dw-ref-svg').forEach(function (svg) {
                        svg.classList.toggle('d-none', svg.getAttribute('data-type') !== type);
                    });
                });
            });
        })();
    </script>
}


