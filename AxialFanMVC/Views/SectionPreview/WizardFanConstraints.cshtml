@{
    ViewData["Title"] = "New Axial Fan Design";
    Layout = "_LayoutV2";
}

<style>
    .wiz-stepper {
        display: flex;
        align-items: center;
        overflow-x: auto;
        gap: 0.25rem;
        padding: 0.75rem 1rem;
        background: #fff;
        border: 1px solid var(--v2-border, #e2e6e4);
        border-radius: 0.5rem;
    }

    .wiz-step {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        white-space: nowrap;
        color: #8a9694;
        font-size: 0.85rem;
        padding: 0.25rem 0.6rem;
    }

        .wiz-step .num {
            width: 22px;
            height: 22px;
            border-radius: 50%;
            border: 1px solid #cfd6d5;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 0.75rem;
            flex-shrink: 0;
        }

        .wiz-step.active {
            color: var(--v2-accent, #3E7C8C);
            font-weight: 600;
        }

            .wiz-step.active .num {
                background: var(--v2-accent, #3E7C8C);
                border-color: var(--v2-accent, #3E7C8C);
                color: #fff;
            }

        .wiz-step.done .num {
            background: #2e7d32;
            border-color: #2e7d32;
            color: #fff;
        }

    .wiz-step-sep {
        flex-grow: 1;
        height: 1px;
        background: #e2e6e4;
        min-width: 12px;
    }

    .wiz-card {
        background: #fff;
        border: 1px solid var(--v2-border, #e2e6e4);
        border-radius: 0.5rem;
        padding: 1.25rem;
    }

    .wiz-section-title {
        color: var(--v2-accent, #3E7C8C);
        font-weight: 600;
        margin-bottom: 1rem;
    }

    .wiz-subheading {
        font-weight: 600;
        font-size: 0.85rem;
        color: #55605e;
        margin-bottom: 0.75rem;
    }

    .wiz-summary-row {
        display: flex;
        justify-content: space-between;
        padding: 0.4rem 0;
        border-bottom: 1px solid #f0f2f1;
        font-size: 0.875rem;
    }

        .wiz-summary-row:last-child {
            border-bottom: none;
        }

    .wiz-summary-label {
        color: #8a9694;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0 fw-bold">New Axial Fan Design</h4>
    <div class="d-flex gap-2">
        <button class="v2-back-btn" type="button" disabled><i class="bi bi-arrow-left"></i> Back</button>
        <button class="btn btn-primary btn-sm" type="button" disabled>Next <i class="bi bi-arrow-right"></i></button>
    </div>
</div>

<div class="wiz-stepper mb-3">
    @{
        var steps = new (int Num, string Label, string State)[]
        {
    (1, "Project Info", "done"), (2, "Air Input", "done"), (3, "Fan Constraints", "active"),
    (4, "Design & Results", ""), (5, "Performance", ""), (6, "Motor", ""),
    (7, "Accessories", ""), (8, "Output & Save", "")
        };
    }
    @for (int i = 0; i < steps.Length; i++)
    {
        var s = steps[i];
        <div class="wiz-step @s.State">
            <span class="num">@(s.State == "done" ? "✓" : s.Num.ToString())</span>
            <span>@s.Label</span>
        </div>
        if (i < steps.Length - 1)
        {
            <div class="wiz-step-sep"></div>
        }
    }
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <div class="wiz-card">
            <div class="wiz-section-title">Fan Constraints</div>

            <div class="wiz-subheading">Geometric Limits</div>
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label small">Hub-to-Tip Ratio</label>
                    <input type="text" class="form-control form-control-sm" value="0.45" disabled />
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Number of Blades</label>
                    <select class="form-select form-select-sm" disabled><option>8</option></select>
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Min Fan Diameter</label>
                    <div class="input-group input-group-sm">
                        <input type="text" class="form-control" value="800" disabled />
                        <span class="input-group-text">mm</span>
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Max Fan Diameter</label>
                    <div class="input-group input-group-sm">
                        <input type="text" class="form-control" value="1600" disabled />
                        <span class="input-group-text">mm</span>
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Max Tip Speed</label>
                    <div class="input-group input-group-sm">
                        <input type="text" class="form-control" value="65" disabled />
                        <span class="input-group-text">m/s</span>
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Speed (RPM) Range</label>
                    <div class="input-group input-group-sm">
                        <input type="text" class="form-control" value="750 – 1450" disabled />
                        <span class="input-group-text">RPM</span>
                    </div>
                </div>
            </div>

            <div class="wiz-subheading">Material &amp; Performance Limits</div>
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label small">Blade Material</label>
                    <select class="form-select form-select-sm" disabled><option>Aluminium Alloy (Cast)</option></select>
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Casing Material</label>
                    <select class="form-select form-select-sm" disabled><option>MS Sheet (3mm)</option></select>
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Max Noise Level</label>
                    <div class="input-group input-group-sm">
                        <input type="text" class="form-control" value="85" disabled />
                        <span class="input-group-text">dB(A)</span>
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Target Efficiency</label>
                    <div class="input-group input-group-sm">
                        <input type="text" class="form-control" value="75" disabled />
                        <span class="input-group-text">%</span>
                    </div>
                </div>
            </div>

            <div class="alert alert-info py-2 px-3 small d-flex align-items-start gap-2 mb-3">
                <i class="bi bi-info-circle-fill mt-1"></i>
                <span>These limits constrain the design calculation in the next step. Leave a field blank to let the engine optimize it automatically.</span>
            </div>

            <div class="d-flex justify-content-between">
                <button class="btn btn-outline-secondary btn-sm" disabled><i class="bi bi-arrow-counterclockwise me-1"></i>Reset</button>
                <button class="btn btn-primary btn-sm" disabled>Next <i class="bi bi-arrow-right"></i></button>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="wiz-card mb-3">
            <div class="wiz-section-title">Constraint Summary</div>
            <div class="wiz-summary-row"><span class="wiz-summary-label">Hub-to-Tip Ratio</span><span>0.45</span></div>
            <div class="wiz-summary-row"><span class="wiz-summary-label">Blades</span><span>8</span></div>
            <div class="wiz-summary-row"><span class="wiz-summary-label">Diameter Range</span><span>800 – 1600 mm</span></div>
            <div class="wiz-summary-row"><span class="wiz-summary-label">Max Tip Speed</span><span>65 m/s</span></div>
            <div class="wiz-summary-row"><span class="wiz-summary-label">RPM Range</span><span>750 – 1450</span></div>
        </div>
        <div class="wiz-card" style="background:#fff8ea; border-color:#f5e3b3;">
            <div class="fw-semibold mb-2"><i class="bi bi-lightbulb-fill text-warning me-1"></i>Tips</div>
            <ul class="small mb-0 ps-3">
                <li>Lower hub-to-tip ratio increases flow capacity but reduces structural rigidity.</li>
                <li>Tip speed above 70 m/s significantly increases noise.</li>
                <li>Leave diameter range wide for maximum design flexibility.</li>
            </ul>
        </div>
    </div>
</div>