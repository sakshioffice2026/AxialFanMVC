<h2 class="dw-panel-title mb-3 fw-bold" style="color:var(--v2-accent)">Fan Constraints</h2>
<div class="row g-3">
    <div class="col-md-6">
        <label class="form-label">Max Tip Diameter</label>
        <div class="input-group">
            <input type="text" class="form-control" value="900">
            <span class="input-group-text">mm</span>
        </div>
    </div>
    <div class="col-md-6">
        <label class="form-label">Min Required Efficiency</label>
        <div class="input-group">
            <input type="text" class="form-control" value="75">
            <span class="input-group-text">%</span>
        </div>
    </div>
    <div class="col-md-6">
        <label class="form-label">Max Noise Level</label>
        <div class="input-group">
            <input type="text" class="form-control" value="85">
            <span class="input-group-text">dB(A)</span>
        </div>
    </div>
    <div class="col-md-6">
        <label class="form-label">Max Motor Power</label>
        <div class="input-group">
            <input type="text" class="form-control" value="15">
            <span class="input-group-text">kW</span>
        </div>
    </div>
    <div class="col-md-6">
        <label class="form-label">Preferred Blade Count</label>
        <select class="form-select">
            <option>6</option><option selected>8</option><option>10</option><option>12</option>
        </select>
    </div>
    <div class="col-md-6">
        <label class="form-label">Max Speed</label>
        <div class="input-group">
            <input type="text" class="form-control" value="1450">
            <span class="input-group-text">RPM</span>
        </div>
    </div>
</div>
