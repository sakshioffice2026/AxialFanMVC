@{
    ViewData["Title"] = "New Axial Fan Design";
    Layout = "_LayoutV2";
}

<style>
    .wiz-stepper {
        display: flex;
        align-items: center;
        overflow-x: auto;
        gap: 0.25rem;
        padding: 0.75rem 1rem;
        background: #fff;
        border: 1px solid var(--v2-border, #e2e6e4);
        border-radius: 0.5rem;
    }

    .wiz-step {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        white-space: nowrap;
        color: #8a9694;
        font-size: 0.85rem;
        padding: 0.25rem 0.6rem;
    }

        .wiz-step .num {
            width: 22px;
            height: 22px;
            border-radius: 50%;
            border: 1px solid #cfd6d5;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 0.75rem;
            flex-shrink: 0;
        }

        .wiz-step.active {
            color: var(--v2-accent, #3E7C8C);
            font-weight: 600;
        }

            .wiz-step.active .num {
                background: var(--v2-accent, #3E7C8C);
                border-color: var(--v2-accent, #3E7C8C);
                color: #fff;
            }

        .wiz-step.done .num {
            background: #2e7d32;
            border-color: #2e7d32;
            color: #fff;
        }

    .wiz-step-sep {
        flex-grow: 1;
        height: 1px;
        background: #e2e6e4;
        min-width: 12px;
    }

    .wiz-card {
        background: #fff;
        border: 1px solid var(--v2-border, #e2e6e4);
        border-radius: 0.5rem;
        padding: 1.25rem;
    }

    .wiz-section-title {
        color: var(--v2-accent, #3E7C8C);
        font-weight: 600;
        margin-bottom: 1rem;
    }

    .wiz-dwg-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.45rem 0;
        border-bottom: 1px solid #f0f2f1;
        font-size: 0.875rem;
    }

        .wiz-dwg-item:last-child {
            border-bottom: none;
        }
</style>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0 fw-bold">New Axial Fan Design</h4>
    <div class="d-flex gap-2">
        <button class="v2-back-btn" type="button" disabled><i class="bi bi-arrow-left"></i> Back</button>
        <button class="btn btn-primary btn-sm" type="button" disabled>Save Design</button>
    </div>
</div>

<div class="wiz-stepper mb-3">
    @{
        var steps = new (int Num, string Label, string State)[]
        {
    (1, "Project Info", "done"), (2, "Air Input", "done"), (3, "Fan Constraints", "done"),
    (4, "Design & Results", "done"), (5, "Performance", "done"), (6, "Motor", "done"),
    (7, "Accessories", "done"), (8, "Output & Save", "active")
        };
    }
    @for (int i = 0; i < steps.Length; i++)
    {
        var s = steps[i];
        <div class="wiz-step @s.State">
            <span class="num">@(s.State == "done" ? "✓" : s.Num.ToString())</span>
            <span>@s.Label</span>
        </div>
        if (i < steps.Length - 1)
        {
            <div class="wiz-step-sep"></div>
        }
    }
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <div class="wiz-card mb-3">
            <div class="wiz-section-title">Capacity Marking</div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label small">Nameplate Fan Model</label>
                    <input type="text" class="form-control form-control-sm" value="AF-1250-D-08" disabled />
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Serial Number Prefix</label>
                    <input type="text" class="form-control form-control-sm" value="CTF-2026-" disabled />
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Rated Capacity</label>
                    <input type="text" class="form-control form-control-sm" value="25.0 m³/s @@ 650 Pa" disabled />
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Rated Power</label>
                    <input type="text" class="form-control form-control-sm" value="18.5 kW" disabled />
                </div>
            </div>
        </div>

        <div class="wiz-card">
            <div class="wiz-section-title">Drawing Generation (7 DXF Drawings)</div>
            @{
                var drawings = new[] { "General Arrangement", "Front Elevation", "Cross Section", "Blade Profile", "Blade Angle Detail", "Foundation Layout", "Motor Mounting Detail" };
            }
            @foreach (var d in drawings)
            {
                <div class="wiz-dwg-item">
                    <i class="bi bi-check-circle-fill text-success"></i>
                    <span class="flex-grow-1">@d</span>
                    <span class="badge bg-success">Ready</span>
                </div>
            }
        </div>
    </div>

    <div class="col-lg-4">
        <div class="wiz-card mb-3">
            <div class="wiz-section-title">Final Review</div>
            <div class="d-flex justify-content-between small py-1 border-bottom"><span class="text-muted">Project</span><span>Cement Plant – ID Fan</span></div>
            <div class="d-flex justify-content-between small py-1 border-bottom"><span class="text-muted">Fan Diameter</span><span>1250 mm</span></div>
            <div class="d-flex justify-content-between small py-1 border-bottom"><span class="text-muted">Motor</span><span>18.5 kW / TEFC</span></div>
            <div class="d-flex justify-content-between small py-1"><span class="text-muted">Accessories</span><span>3 selected</span></div>
        </div>
        <div class="d-grid gap-2">
            <button class="btn btn-primary" disabled><i class="bi bi-save me-1"></i>Save Design</button>
            <button class="btn btn-outline-secondary" disabled><i class="bi bi-download me-1"></i>Export DXF Package</button>
        </div>
    </div>
</div>