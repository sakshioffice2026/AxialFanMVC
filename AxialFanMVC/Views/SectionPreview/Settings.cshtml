@{
    ViewData["Title"] = "Settings Preview";
    Layout = "_LayoutV2";
}

<h2 class="mb-1"><i class="bi bi-gear me-2"></i>Settings</h2>
<p class="text-muted mb-4">Dummy preview — not a real feature yet.</p>

<div class="card border-0 shadow-sm" style="max-width: 480px;">
    <div class="card-body">
        <div class="mb-3">
            <label class="form-label small text-muted">Display Name</label>
            <input type="text" class="form-control" value="Sham P" disabled />
        </div>
        <div class="mb-3">
            <label class="form-label small text-muted">Default Units</label>
            <select class="form-select" disabled>
                <option>Metric (m³/s, Pa, mm)</option>
                <option>Imperial (CFM, in.wg, in)</option>
            </select>
        </div>
        <div class="mb-3">
            <label class="form-label small text-muted">Theme</label>
            <select class="form-select" disabled>
                <option>AxialFlow Default</option>
            </select>
        </div>
        <button class="btn btn-primary" disabled>Save Changes</button>
    </div>
</div>