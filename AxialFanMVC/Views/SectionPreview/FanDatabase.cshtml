@{
    ViewData["Title"] = "Fan Database";
}

<style>
    .fdb-heading { font-family: 'Space Grotesk', 'Segoe UI', sans-serif; }
    .fdb-stat-card {
        background: var(--v2-surface); border: 1px solid var(--v2-border); border-radius: 6px;
        padding: 1rem 1.2rem; border-left: 3px solid var(--v2-accent); height: 100%;
    }
    .fdb-stat-label { font-size: .75rem; text-transform: uppercase; letter-spacing: .05em; color: #8a938f; font-weight: 600; }
    .fdb-stat-value { font-size: 1.7rem; font-weight: 700; color: #22302e; font-variant-numeric: tabular-nums; }
    .fdb-panel { background: var(--v2-surface); border: 1px solid var(--v2-border); border-radius: 6px; padding: 1.25rem 1.4rem; }
    .fdb-table thead th { font-size: .7rem; text-transform: uppercase; letter-spacing: .04em; color: #8a938f; border-bottom: 1px solid var(--v2-border); font-weight: 700; }
    .fdb-table td { vertical-align: middle; font-size: .875rem; }
    .fdb-table tbody tr:hover { background: color-mix(in srgb, var(--v2-accent) 6%, white); }
    .fdb-badge { font-size: .7rem; font-weight: 600; padding: .3em .65em; border-radius: 4px; }
    .fdb-badge.active { background: #e4f5eb; color: #1f7a44; }
    .fdb-badge.discontinued { background: #f6e3e1; color: #a13a2f; }
    .fdb-badge.draft { background: #eef0ef; color: #6b7674; }
</style>

<div class="d-flex align-items-end justify-content-between flex-wrap gap-2 mb-3">
    <div>
        <h1 class="fdb-heading h4 fw-bold mb-1">
            <i class="bi bi-hdd-stack me-2" style="color:var(--v2-accent)"></i>Fan Database
        </h1>
        <div class="small text-muted">
            Catalog of finished fan models generated from validated designs — dummy data (preview only)
        </div>
    </div>
    
</div>

<div class="row g-3 mb-3">
    <div class="col-6 col-xl-3">
        <div class="fdb-stat-card">
            <div class="fdb-stat-label">Total Models</div>
            <div class="fdb-stat-value">24</div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="fdb-stat-card">
            <div class="fdb-stat-label">Active Models</div>
            <div class="fdb-stat-value">18</div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="fdb-stat-card">
            <div class="fdb-stat-label">In Draft</div>
            <div class="fdb-stat-value">4</div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="fdb-stat-card">
            <div class="fdb-stat-label">Series Groups</div>
            <div class="fdb-stat-value">6</div>
        </div>
    </div>
</div>

<div class="fdb-panel">
    <h2 class="h6 fw-bold mb-3">Fan Models <small class="text-muted fw-normal">(dummy data)</small></h2>
    <div class="table-responsive">
        <table class="table fdb-table mb-0">
            <thead>
                <tr>
                    <th>Model No.</th>
                    <th>Series</th>
                    <th>Tip Diameter</th>
                    <th>Motor</th>
                    <th>Flow Range</th>
                    <th>Pressure Range</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="fw-semibold">AF-630</td>
                    <td>AF Series</td>
                    <td>630 mm</td>
                    <td>5.5 kW</td>
                    <td>8 – 14 m³/s</td>
                    <td>400 – 700 Pa</td>
                    <td><span class="fdb-badge active">Active</span></td>
                    <td class="text-end"><a href="#" class="text-muted"><i class="bi bi-eye"></i></a></td>
                </tr>
                <tr>
                    <td class="fw-semibold">AF-710</td>
                    <td>AF Series</td>
                    <td>710 mm</td>
                    <td>7.5 kW</td>
                    <td>12 – 19 m³/s</td>
                    <td>450 – 750 Pa</td>
                    <td><span class="fdb-badge active">Active</span></td>
                    <td class="text-end"><a href="#" class="text-muted"><i class="bi bi-eye"></i></a></td>
                </tr>
                <tr>
                    <td class="fw-semibold">AF-800</td>
                    <td>AF Series</td>
                    <td>800 mm</td>
                    <td>11 kW</td>
                    <td>18 – 27 m³/s</td>
                    <td>500 – 820 Pa</td>
                    <td><span class="fdb-badge active">Active</span></td>
                    <td class="text-end"><a href="#" class="text-muted"><i class="bi bi-eye"></i></a></td>
                </tr>
                <tr>
                    <td class="fw-semibold">AF-900</td>
                    <td>AF Series</td>
                    <td>900 mm</td>
                    <td>15 kW</td>
                    <td>24 – 34 m³/s</td>
                    <td>550 – 880 Pa</td>
                    <td><span class="fdb-badge draft">Draft</span></td>
                    <td class="text-end"><a href="#" class="text-muted"><i class="bi bi-eye"></i></a></td>
                </tr>
                <tr>
                    <td class="fw-semibold">AF-1000</td>
                    <td>AF Series</td>
                    <td>1000 mm</td>
                    <td>18.5 kW</td>
                    <td>30 – 42 m³/s</td>
                    <td>600 – 950 Pa</td>
                    <td><span class="fdb-badge draft">Draft</span></td>
                    <td class="text-end"><a href="#" class="text-muted"><i class="bi bi-eye"></i></a></td>
                </tr>
                <tr>
                    <td class="fw-semibold">HD-500</td>
                    <td>HD Series</td>
                    <td>500 mm</td>
                    <td>3.7 kW</td>
                    <td>5 – 9 m³/s</td>
                    <td>350 – 600 Pa</td>
                    <td><span class="fdb-badge discontinued">Discontinued</span></td>
                    <td class="text-end"><a href="#" class="text-muted"><i class="bi bi-eye"></i></a></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
