@{
    ViewData["Title"] = "My Drawings Preview";
    Layout = "_LayoutV2";
}

<h2 class="mb-1"><i class="bi bi-file-earmark-text me-2"></i>My Drawings</h2>
<p class="text-muted mb-4">Dummy preview — not a real feature yet.</p>

<div class="row g-3">
    @{
        var drawings = new[]
        {
    ("DWG001_FrontElev", "Front Elevation", "02 Jul 2026"),
    ("DWG002_CrossSection", "Cross Section", "02 Jul 2026"),
    ("DWG003_BladeProfile", "Blade Profile", "28 Jun 2026"),
    ("DWG004_BladeAngle", "Blade Angle Detail", "28 Jun 2026")
    };
    }
    @foreach (var (code, title, date) in drawings)
    {
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <i class="bi bi-file-earmark-ruled fs-1 text-muted"></i>
                    <div class="fw-semibold mt-2">@title</div>
                    <div class="text-muted small">@code &middot; @date</div>
                </div>
            </div>
        </div>
    }
</div>