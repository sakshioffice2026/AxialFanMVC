<h2 class="dw-panel-title mb-3 fw-bold" style="color:var(--v2-accent)">Accessories</h2>
<div class="row g-3">
    <div class="col-md-6 form-check">
        <input type="checkbox" class="form-check-input" id="accInletGuard" checked>
        <label class="form-check-label" for="accInletGuard">Inlet Safety Guard</label>
    </div>
    <div class="col-md-6 form-check">
        <input type="checkbox" class="form-check-input" id="accOutletGuard" checked>
        <label class="form-check-label" for="accOutletGuard">Outlet Safety Guard</label>
    </div>
    <div class="col-md-6 form-check">
        <input type="checkbox" class="form-check-input" id="accVibration">
        <label class="form-check-label" for="accVibration">Vibration Isolators</label>
    </div>
    <div class="col-md-6 form-check">
        <input type="checkbox" class="form-check-input" id="accFlexConn" checked>
        <label class="form-check-label" for="accFlexConn">Flexible Duct Connector</label>
    </div>
    <div class="col-md-6 form-check">
        <input type="checkbox" class="form-check-input" id="accSilencer">
        <label class="form-check-label" for="accSilencer">Inlet/Outlet Silencer</label>
    </div>
    <div class="col-md-6 form-check">
        <input type="checkbox" class="form-check-input" id="accDamper">
        <label class="form-check-label" for="accDamper">Backdraft Damper</label>
    </div>
</div>
<div class="mt-3">
    <label class="form-label">Accessory Notes</label>
    <textarea class="form-control" rows="3" placeholder="Any special accessory requirements..."></textarea>
</div>
