@{
    ViewData["Title"] = "New Axial Fan Design";
    Layout = "_LayoutV2";
}

<style>
    .wiz-stepper {
        display: flex;
        align-items: center;
        overflow-x: auto;
        gap: 0.25rem;
        padding: 0.75rem 1rem;
        background: #fff;
        border: 1px solid var(--v2-border, #e2e6e4);
        border-radius: 0.5rem;
    }

    .wiz-step {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        white-space: nowrap;
        color: #8a9694;
        font-size: 0.85rem;
        padding: 0.25rem 0.6rem;
    }

        .wiz-step .num {
            width: 22px;
            height: 22px;
            border-radius: 50%;
            border: 1px solid #cfd6d5;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 0.75rem;
            flex-shrink: 0;
        }

        .wiz-step.active {
            color: var(--v2-accent, #3E7C8C);
            font-weight: 600;
        }

            .wiz-step.active .num {
                background: var(--v2-accent, #3E7C8C);
                border-color: var(--v2-accent, #3E7C8C);
                color: #fff;
            }

        .wiz-step.done .num {
            background: #2e7d32;
            border-color: #2e7d32;
            color: #fff;
        }

    .wiz-step-sep {
        flex-grow: 1;
        height: 1px;
        background: #e2e6e4;
        min-width: 12px;
    }

    .wiz-card {
        background: #fff;
        border: 1px solid var(--v2-border, #e2e6e4);
        border-radius: 0.5rem;
        padding: 1.25rem;
    }

    .wiz-section-title {
        color: var(--v2-accent, #3E7C8C);
        font-weight: 600;
        margin-bottom: 1rem;
    }

    .wiz-result-tile {
        border: 1px solid #f0f2f1;
        border-radius: 0.4rem;
        padding: 0.75rem 1rem;
        text-align: center;
        height: 100%;
    }

        .wiz-result-tile .val {
            font-size: 1.25rem;
            font-weight: 700;
            color: #22302e;
        }

        .wiz-result-tile .lbl {
            font-size: 0.75rem;
            color: #8a9694;
        }
</style>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0 fw-bold">New Axial Fan Design</h4>
    <div class="d-flex gap-2">
        <button class="v2-back-btn" type="button" disabled><i class="bi bi-arrow-left"></i> Back</button>
        <button class="btn btn-primary btn-sm" type="button" disabled>Next <i class="bi bi-arrow-right"></i></button>
    </div>
</div>

<div class="wiz-stepper mb-3">
    @{
        var steps = new (int Num, string Label, string State)[]
        {
    (1, "Project Info", "done"), (2, "Air Input", "done"), (3, "Fan Constraints", "done"),
    (4, "Design & Results", "active"), (5, "Performance", ""), (6, "Motor", ""),
    (7, "Accessories", ""), (8, "Output & Save", "")
        };
    }
    @for (int i = 0; i < steps.Length; i++)
    {
        var s = steps[i];
        <div class="wiz-step @s.State">
            <span class="num">@(s.State == "done" ? "✓" : s.Num.ToString())</span>
            <span>@s.Label</span>
        </div>
        if (i < steps.Length - 1)
        {
            <div class="wiz-step-sep"></div>
        }
    }
</div>

<div class="wiz-card mb-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="wiz-section-title mb-0">Design &amp; Results</div>
        <button class="btn btn-sm btn-outline-primary" disabled><i class="bi bi-arrow-repeat me-1"></i>Recalculate</button>
    </div>

    <div class="row g-3">
        @{
            var results = new (string Label, string Value)[]
            {
        ("Fan Diameter", "1250 mm"), ("Hub Diameter", "562 mm"), ("No. of Blades", "8"),
        ("Blade Angle", "32.5°"), ("Design RPM", "1450"), ("Power Required", "18.4 kW"),
        ("Static Efficiency", "78.2%"), ("Tip Speed", "94.9 m/s"), ("Specific Speed", "0.68")
            };
        }
        @foreach (var r in results)
        {
            <div class="col-md-4 col-6">
                <div class="wiz-result-tile">
                    <div class="val">@r.Value</div>
                    <div class="lbl">@r.Label</div>
                </div>
            </div>
        }
    </div>

    <div class="alert alert-warning py-2 px-3 small d-flex align-items-start gap-2 mt-3 mb-0">
        <i class="bi bi-exclamation-triangle-fill mt-1"></i>
        <span>Tip speed (94.9 m/s) exceeds the max tip speed constraint entered in Step 3 (65 m/s). Review Fan Constraints before proceeding.</span>
    </div>
</div>

<div class="d-flex justify-content-between">
    <button class="btn btn-outline-secondary btn-sm" disabled><i class="bi bi-arrow-counterclockwise me-1"></i>Reset</button>
    <button class="btn btn-primary btn-sm" disabled>Next <i class="bi bi-arrow-right"></i></button>
</div>