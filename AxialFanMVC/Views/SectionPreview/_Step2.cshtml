@model AxialFanMVC.ViewModels.DesignWizardViewModel

<h2 class="dw-panel-title mb-3 fw-bold" style="color:var(--v2-accent)">
    Air Input
</h2>

<div class="text-uppercase small fw-bold text-muted mb-2" style="letter-spacing:.04em;">
    Operating Conditions
</div>

<div class="row g-3">

    <!-- Flow Rate -->
    <div class="col-md-6">
        <label asp-for="FlowRateM3s" class="form-label"></label>
        <div class="input-group">
            <input asp-for="FlowRateM3s"
                   class="form-control"
                   id="FlowRateM3s" />

            <span class="input-group-text">m³/s</span>
        </div>

        <span asp-validation-for="FlowRateM3s"
              class="text-danger"></span>
    </div>

    <!-- Gas Type -->
    <div class="col-md-6">
        <label asp-for="MediaType" class="form-label"></label>

        <select asp-for="MediaType" class="form-select">
            <option value="">-- Select --</option>
            <option>Air</option>
            <option>Clean Air</option>
            <option>Fresh Air</option>
            <option>Hot Air</option>
            <option>Flue Gas</option>
        </select>

        <span asp-validation-for="MediaType"
              class="text-danger"></span>
    </div>

    <!-- Static Pressure -->
    <div class="col-md-6">
        <label asp-for="StaticPressurePa" class="form-label"></label>

        <div class="input-group">
            <input asp-for="StaticPressurePa"
                   class="form-control"
                   id="StaticPressurePa" />

            <span class="input-group-text">Pa</span>
        </div>

        <span asp-validation-for="StaticPressurePa"
              class="text-danger"></span>
    </div>

    <!-- Air Density -->
    <div class="col-md-6">
        <label asp-for="DensityKgM3" class="form-label"></label>

        <div class="input-group">
            <input asp-for="DensityKgM3"
                   class="form-control"
                   id="DensityKgM3" />

            <span class="input-group-text">kg/m³</span>
        </div>

        <span asp-validation-for="DensityKgM3"
              class="text-danger"></span>
    </div>

    <!-- Temperature -->
    <div class="col-md-6">
        <label asp-for="TemperatureCelsius" class="form-label"></label>

        <div class="input-group">
            <input asp-for="TemperatureCelsius"
                   class="form-control"
                   id="TemperatureCelsius" />

            <span class="input-group-text">°C</span>
        </div>

        <span asp-validation-for="TemperatureCelsius"
              class="text-danger"></span>
    </div>
    <!-- Direction -->
    <div class="col-md-6">
        <label asp-for="Direction" class="form-label"></label>

        <select asp-for="Direction" class="form-select">
            <option value="">-- Select --</option>
            <option>Exhaust</option>
            <option>Supply</option>
            <option>Reversible</option>
        </select>

        <span asp-validation-for="Direction" class="text-danger"></span>
    </div>

    <!-- Altitude -->
    <div class="col-md-6">
        <label asp-for="AltitudeM" class="form-label"></label>

        <div class="input-group">
            <input asp-for="AltitudeM"
                   class="form-control"
                   id="AltitudeM" />

            <span class="input-group-text">m</span>
        </div>

        <span asp-validation-for="AltitudeM"
              class="text-danger"></span>
    </div>

    <!-- Installation Type -->
    <div class="col-md-6">
        <label asp-for="InstallationType" class="form-label"></label>

        <select asp-for="InstallationType" class="form-select">
            <option value="">-- Select --</option>
            <option>Ducted – Ducted (Type D)</option>
            <option>Ducted – Free Outlet</option>
            <option>Free Inlet – Ducted Outlet</option>
            <option>Free Inlet – Free Outlet</option>
        </select>

        <span asp-validation-for="InstallationType"
              class="text-danger"></span>
    </div>

    <!-- Atmospheric Pressure -->
    <div class="col-md-6">
        <label asp-for="AtmosphericPressureKPa" class="form-label"></label>

        <div class="input-group">
            <input asp-for="AtmosphericPressureKPa"
                   class="form-control"
                   id="AtmosphericPressureKPa" />

            <span class="input-group-text">kPa</span>
        </div>

        <span asp-validation-for="AtmosphericPressureKPa"
              class="text-danger"></span>
    </div>

    <!-- Duty -->
    <div class="col-md-6">
        <label asp-for="Duty" class="form-label"></label>

        <select asp-for="Duty" class="form-select">
            <option value="">-- Select --</option>
            <option>Continuous</option>
            <option>Intermittent</option>
            <option>Standby</option>
        </select>

        <span asp-validation-for="Duty"
              class="text-danger"></span>
    </div>

    <!-- Relative Humidity -->
    <div class="col-md-6">
        <label asp-for="RelativeHumidityPct" class="form-label"></label>

        <div class="input-group">
            <input asp-for="RelativeHumidityPct"
                   class="form-control"
                   id="RelativeHumidityPct" />

            <span class="input-group-text">%</span>
        </div>

        <span asp-validation-for="RelativeHumidityPct"
              class="text-danger"></span>
    </div>

    <!-- Frequency -->
    <div class="col-md-6">
        <label asp-for="FrequencyHz" class="form-label"></label>

        <div class="input-group">
            <select asp-for="FrequencyHz" class="form-select">
                <option value="50">50</option>
                <option value="60">60</option>
            </select>

            <span class="input-group-text">Hz</span>
        </div>

        <span asp-validation-for="FrequencyHz"
              class="text-danger"></span>
    </div>

    <!-- Total Pressure -->
    <div class="col-md-6">
        <label asp-for="TotalPressurePa" class="form-label"></label>

        <div class="input-group">
            <input asp-for="TotalPressurePa"
                   class="form-control"
                   id="TotalPressurePa" />

            <span class="input-group-text">Pa</span>
        </div>

        <span asp-validation-for="TotalPressurePa"
              class="text-danger"></span>
    </div>

</div>