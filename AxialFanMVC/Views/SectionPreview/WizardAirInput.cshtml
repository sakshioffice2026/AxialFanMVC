@{
    ViewData["Title"] = "New Axial Fan Design";
    Layout = "_LayoutV2";
}

<style>
    /* Scoped to this preview page only */
    .wiz-stepper {
        display: flex;
        align-items: center;
        overflow-x: auto;
        gap: 0.25rem;
        padding: 0.75rem 1rem;
        background: #fff;
        border: 1px solid var(--v2-border, #e2e6e4);
        border-radius: 0.5rem;
    }
    .wiz-step {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        white-space: nowrap;
        color: #8a9694;
        font-size: 0.85rem;
        padding: 0.25rem 0.6rem;
    }
    .wiz-step .num {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        border: 1px solid #cfd6d5;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        flex-shrink: 0;
    }
    .wiz-step.active {
        color: var(--v2-accent, #3E7C8C);
        font-weight: 600;
    }
    .wiz-step.active .num {
        background: var(--v2-accent, #3E7C8C);
        border-color: var(--v2-accent, #3E7C8C);
        color: #fff;
    }
    .wiz-step.done .num {
        background: #2e7d32;
        border-color: #2e7d32;
        color: #fff;
    }
    .wiz-step-sep {
        flex-grow: 1;
        height: 1px;
        background: #e2e6e4;
        min-width: 12px;
    }
    .wiz-card {
        background: #fff;
        border: 1px solid var(--v2-border, #e2e6e4);
        border-radius: 0.5rem;
        padding: 1.25rem;
    }
    .wiz-section-title {
        color: var(--v2-accent, #3E7C8C);
        font-weight: 600;
        margin-bottom: 1rem;
    }
    .wiz-subheading {
        font-weight: 600;
        font-size: 0.85rem;
        color: #55605e;
        margin-bottom: 0.75rem;
    }
    .wiz-summary-row {
        display: flex;
        justify-content: space-between;
        padding: 0.4rem 0;
        border-bottom: 1px solid #f0f2f1;
        font-size: 0.875rem;
    }
    .wiz-summary-row:last-child { border-bottom: none; }
    .wiz-summary-label { color: #8a9694; }
    .wiz-workflow-item {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.4rem 0;
        font-size: 0.875rem;
    }
    .wiz-workflow-num {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
        color: #fff;
        flex-shrink: 0;
    }
    .wiz-refbtn.active {
        background: var(--v2-accent, #3E7C8C);
        color: #fff;
        border-color: var(--v2-accent, #3E7C8C);
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0 fw-bold">New Axial Fan Design</h4>
    <div class="d-flex gap-2">
        <button class="v2-back-btn" type="button" disabled><i class="bi bi-arrow-left"></i> Back</button>
        <button class="btn btn-primary btn-sm" type="button" disabled>Next <i class="bi bi-arrow-right"></i></button>
    </div>
</div>

<div class="wiz-stepper mb-3">
    @{
        var steps = new (int Num, string Label, string State)[]
        {
            (1, "Project Info", "done"),
            (2, "Air Input", "active"),
            (3, "Fan Constraints", ""),
            (4, "Design & Results", ""),
            (5, "Performance", ""),
            (6, "Motor", ""),
            (7, "Accessories", ""),
            (8, "Output & Save", "")
        };
    }
    @for (int i = 0; i < steps.Length; i++)
    {
        var s = steps[i];
        <div class="wiz-step @s.State">
            <span class="num">
                @if (s.State == "done") { <i class="bi bi-check"></i> } else { @s.Num }
            </span>
            <span>@s.Label</span>
        </div>
        if (i < steps.Length - 1)
        {
            <div class="wiz-step-sep"></div>
        }
    }
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <div class="wiz-card">
            <div class="wiz-section-title">Air Input</div>

            <div class="wiz-subheading">Operating Conditions</div>
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label small">Flow Rate <span class="text-danger">*</span></label>
                    <div class="input-group input-group-sm">
                        <input type="text" class="form-control" value="25.00" disabled />
                        <select class="form-select" style="max-width:90px" disabled><option>m³/s</option></select>
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Gas Type</label>
                    <select class="form-select form-select-sm" disabled><option>Air</option></select>
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Static Pressure <span class="text-danger">*</span></label>
                    <div class="input-group input-group-sm">
                        <input type="text" class="form-control" value="650" disabled />
                        <select class="form-select" style="max-width:90px" disabled><option>Pa</option></select>
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Air Density</label>
                    <div class="input-group input-group-sm">
                        <select class="form-select" style="max-width:90px" disabled><option>Auto</option></select>
                        <input type="text" class="form-control" value="1.18" disabled />
                        <span class="input-group-text">kg/m³</span>
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Temperature <span class="text-danger">*</span></label>
                    <div class="input-group input-group-sm">
                        <input type="text" class="form-control" value="40" disabled />
                        <select class="form-select" style="max-width:90px" disabled><option>°C</option></select>
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Direction</label>
                    <select class="form-select form-select-sm" disabled><option>Exhaust</option></select>
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Altitude</label>
                    <div class="input-group input-group-sm">
                        <input type="text" class="form-control" value="250" disabled />
                        <select class="form-select" style="max-width:90px" disabled><option>m</option></select>
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Installation Type</label>
                    <select class="form-select form-select-sm" disabled><option>Ducted – Ducted (Type D)</option></select>
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Atmospheric Pressure</label>
                    <div class="input-group input-group-sm">
                        <input type="text" class="form-control" value="101.3" disabled />
                        <select class="form-select" style="max-width:90px" disabled><option>kPa</option></select>
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Duty</label>
                    <select class="form-select form-select-sm" disabled><option>Continuous</option></select>
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Relative Humidity</label>
                    <div class="input-group input-group-sm">
                        <input type="text" class="form-control" value="60" disabled />
                        <select class="form-select" style="max-width:90px" disabled><option>%</option></select>
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Frequency</label>
                    <div class="input-group input-group-sm">
                        <select class="form-select" disabled><option>50</option></select>
                        <span class="input-group-text">Hz</span>
                    </div>
                </div>
            </div>

            <label class="form-label small">Additional Information (Optional)</label>
            <textarea class="form-control form-control-sm mb-3" rows="2" placeholder="Any additional notes about the operating conditions..." disabled></textarea>

            <div class="alert alert-info py-2 px-3 small d-flex align-items-start gap-2 mb-3">
                <i class="bi bi-info-circle-fill mt-1"></i>
                <span>Density and other properties are auto calculated based on the above inputs. You can change Air Density manually if required.</span>
            </div>

            <div class="d-flex justify-content-between">
                <button class="btn btn-outline-secondary btn-sm" disabled><i class="bi bi-arrow-counterclockwise me-1"></i>Reset</button>
                <button class="btn btn-primary btn-sm" disabled>Next <i class="bi bi-arrow-right"></i></button>
            </div>
        </div>

        <div class="wiz-card mt-3">
            <div class="wiz-section-title">Typical Axial Fan <span class="text-muted fw-normal small">(Reference)</span></div>
            <div class="d-flex gap-2 mb-3 flex-wrap">
                <button class="btn btn-sm wiz-refbtn active" disabled>Long Case</button>
                <button class="btn btn-sm btn-outline-secondary" disabled>Short Case</button>
                <button class="btn btn-sm btn-outline-secondary" disabled>Wall Mounted</button>
                <button class="btn btn-sm btn-outline-secondary" disabled>Roof Mounted</button>
                <button class="btn btn-sm btn-outline-secondary" disabled>Plate Mounted</button>
                <button class="btn btn-sm btn-outline-secondary" disabled>Duct Mounted</button>
            </div>
            <div class="row g-3 text-center">
                <div class="col-md-4">
                    <div class="border rounded p-3" style="height:150px" >
                        <i class="bi bi-fan" style="font-size:5rem; color:#6c757d;"></i>
                    </div>
                    <div class="small text-muted mt-1">3D Reference</div>
                </div>
                <div class="col-md-4">
                    <div class="border rounded p-3 d-flex align-items-center justify-content-center" style="height:150px">
                        <i class="bi bi-rulers" style="font-size:3rem; color:#adb5bd;"></i>
                    </div>
                    <div class="small text-muted mt-1">ØA · ØC · L Dimensions</div>
                </div>
                <div class="col-md-4">
                    <div class="border rounded p-3 d-flex align-items-center justify-content-center" style="height:150px">
                        <i class="bi bi-circle" style="font-size:4rem; color:#adb5bd;"></i>
                    </div>
                    <div class="small text-muted mt-1">Rear View Schematic</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="wiz-card mb-3">
            <div class="wiz-section-title">Air Properties <span class="text-muted fw-normal small">(Calculated)</span></div>
            <div class="wiz-summary-row"><span class="wiz-summary-label">Air Density</span><span>1.18 kg/m³</span></div>
            <div class="wiz-summary-row"><span class="wiz-summary-label">Viscosity</span><span>1.91E-05 Pa.s</span></div>
            <div class="wiz-summary-row"><span class="wiz-summary-label">Speed of Sound</span><span>354.6 m/s</span></div>
            <div class="wiz-summary-row"><span class="wiz-summary-label">Density Correction Factor</span><span>1.03</span></div>
            <div class="wiz-summary-row"><span class="wiz-summary-label">Volume Flow @@ Std. Conditions</span><span>24.28 m³/s</span></div>
        </div>

        <div class="wiz-card mb-3">
            <div class="wiz-section-title">Project Summary</div>
            <div class="wiz-summary-row"><span class="wiz-summary-label">Project Name</span><span>Cement Plant – ID Fan</span></div>
            <div class="wiz-summary-row"><span class="wiz-summary-label">Client</span><span>ABC Industries Ltd.</span></div>
            <div class="wiz-summary-row"><span class="wiz-summary-label">Application</span><span>Industrial Ventilation</span></div>
            <div class="wiz-summary-row"><span class="wiz-summary-label">Engineer</span><span>Engineer</span></div>
            <div class="wiz-summary-row"><span class="wiz-summary-label">Date</span><span>30 May 2025</span></div>
        </div>

        <div class="wiz-card mb-3">
            <div class="wiz-section-title">Design Workflow</div>
            @{
                var workflow = new (int Num, string Label, string Status, string Color)[]
                {
                    (1, "Project Information", "Completed", "#2e7d32"),
                    (2, "Air Input", "In Progress", "#3E7C8C"),
                    (3, "Fan Constraints", "Pending", "#adb5bd"),
                    (4, "Design & Results", "Pending", "#adb5bd"),
                    (5, "Performance Curves", "Pending", "#adb5bd"),
                    (6, "Motor Selection", "Pending", "#adb5bd"),
                    (7, "Accessories", "Pending", "#adb5bd"),
                    (8, "Output & Save", "Pending", "#adb5bd")
                };
            }
            @foreach (var w in workflow)
            {
                <div class="wiz-workflow-item">
                    <span class="wiz-workflow-num" style="background:@w.Color">@w.Num</span>
                    <span class="flex-grow-1">@w.Label</span>
                    <span class="small" style="color:@w.Color">@w.Status</span>
                </div>
            }
        </div>

        <div class="wiz-card" style="background:#fff8ea; border-color:#f5e3b3;">
            <div class="fw-semibold mb-2"><i class="bi bi-lightbulb-fill text-warning me-1"></i>Tips</div>
            <ul class="small mb-0 ps-3">
                <li>Enter the required Air Flow and Static Pressure accurately.</li>
                <li>Air properties affect fan performance. Provide correct temperature and altitude.</li>
                <li>Installation type selection is important for accurate performance.</li>
                <li>You can review and change inputs anytime before final calculation.</li>
            </ul>
        </div>
    </div>
</div>