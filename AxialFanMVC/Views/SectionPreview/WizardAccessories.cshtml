@{
    ViewData["Title"] = "New Axial Fan Design";
    Layout = "_LayoutV2";
}

<style>
    .wiz-stepper {
        display: flex;
        align-items: center;
        overflow-x: auto;
        gap: 0.25rem;
        padding: 0.75rem 1rem;
        background: #fff;
        border: 1px solid var(--v2-border, #e2e6e4);
        border-radius: 0.5rem;
    }

    .wiz-step {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        white-space: nowrap;
        color: #8a9694;
        font-size: 0.85rem;
        padding: 0.25rem 0.6rem;
    }

        .wiz-step .num {
            width: 22px;
            height: 22px;
            border-radius: 50%;
            border: 1px solid #cfd6d5;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 0.75rem;
            flex-shrink: 0;
        }

        .wiz-step.active {
            color: var(--v2-accent, #3E7C8C);
            font-weight: 600;
        }

            .wiz-step.active .num {
                background: var(--v2-accent, #3E7C8C);
                border-color: var(--v2-accent, #3E7C8C);
                color: #fff;
            }

        .wiz-step.done .num {
            background: #2e7d32;
            border-color: #2e7d32;
            color: #fff;
        }

    .wiz-step-sep {
        flex-grow: 1;
        height: 1px;
        background: #e2e6e4;
        min-width: 12px;
    }

    .wiz-card {
        background: #fff;
        border: 1px solid var(--v2-border, #e2e6e4);
        border-radius: 0.5rem;
        padding: 1.25rem;
    }

    .wiz-section-title {
        color: var(--v2-accent, #3E7C8C);
        font-weight: 600;
        margin-bottom: 1rem;
    }

    .wiz-acc-item {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.6rem 0.75rem;
        border: 1px solid #f0f2f1;
        border-radius: 0.4rem;
        margin-bottom: 0.5rem;
    }

        .wiz-acc-item.checked {
            border-color: var(--v2-accent, #3E7C8C);
            background: #f2f8f9;
        }
</style>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0 fw-bold">New Axial Fan Design</h4>
    <div class="d-flex gap-2">
        <button class="v2-back-btn" type="button" disabled><i class="bi bi-arrow-left"></i> Back</button>
        <button class="btn btn-primary btn-sm" type="button" disabled>Next <i class="bi bi-arrow-right"></i></button>
    </div>
</div>

<div class="wiz-stepper mb-3">
    @{
        var steps = new (int Num, string Label, string State)[]
        {
    (1, "Project Info", "done"), (2, "Air Input", "done"), (3, "Fan Constraints", "done"),
    (4, "Design & Results", "done"), (5, "Performance", "done"), (6, "Motor", "done"),
    (7, "Accessories", "active"), (8, "Output & Save", "")
        };
    }
    @for (int i = 0; i < steps.Length; i++)
    {
        var s = steps[i];
        <div class="wiz-step @s.State">
            <span class="num">@(s.State == "done" ? "✓" : s.Num.ToString())</span>
            <span>@s.Label</span>
        </div>
        if (i < steps.Length - 1)
        {
            <div class="wiz-step-sep"></div>
        }
    }
</div>

<div class="wiz-card">
    <div class="wiz-section-title">Accessories</div>
    <p class="text-muted small mb-3">Select the accessories to include with this fan design.</p>

    <div class="row g-2">
        @{
            var accessories = new (string Name, string Desc, bool Checked)[]
            {
        ("Inlet Guide Vanes", "Improves airflow direction at fan inlet", true),
        ("Outlet Guide Vanes", "Recovers swirl energy for efficiency", false),
        ("Damper", "Manual or motorized flow control damper", true),
        ("Silencer", "Reduces noise at inlet/outlet", false),
        ("Anti-Vibration Mounts", "Isolates fan vibration from structure", true),
        ("Flexible Connector", "Absorbs thermal expansion in ductwork", false)
            };
        }
        @foreach (var a in accessories)
        {
            <div class="col-md-6">
                <div class="wiz-acc-item @(a.Checked ? "checked" : "")">
                    <input type="checkbox" class="form-check-input mt-0" checked="@a.Checked" disabled />
                    <div>
                        <div class="fw-semibold small">@a.Name</div>
                        <div class="text-muted small">@a.Desc</div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="d-flex justify-content-between mt-3">
        <button class="btn btn-outline-secondary btn-sm" disabled><i class="bi bi-arrow-counterclockwise me-1"></i>Reset</button>
        <button class="btn btn-primary btn-sm" disabled>Next <i class="bi bi-arrow-right"></i></button>
    </div>
</div>