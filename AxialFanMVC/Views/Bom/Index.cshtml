@model AxialFanMVC.ViewModels.BomViewModel

@{
    ViewData["Title"] = $"BOM & Costing — {Model.ProjectName}";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-controller="Projects" asp-action="Index">
                Projects
            </a>
        </li>

        <li class="breadcrumb-item active">
            BOM &amp; Costing
        </li>
    </ol>
</nav>

<div class="bom-card">

    <div class="bom-card-header">

        <div>
            <h1 class="bom-title">
                BOM &amp; Costing
            </h1>

            <div class="bom-subtitle">
                Select a project and design result to view the BOM.
            </div>
        </div>

    </div>

    <div class="row g-3 mt-2">

        <!-- Project -->
        <div class="col-md-6">

            <label class="form-label fw-semibold">
                Project
            </label>

            <select id="projectSelect"
                    class="form-select">

                <option value="">
                    -- Select Project --
                </option>

                @foreach (var project in Model.AvailableProjects)
                {
                    <option value="@project.ProjectId"
                            selected="@(project.ProjectId == Model.ProjectId)">
                        @project.ProjectName
                    </option>
                }

            </select>

        </div>

        <!-- Design -->
        <div class="col-md-6">

            <label class="form-label fw-semibold">
                Design Result
            </label>

            <select id="designSelect"
                    class="form-select">

                <option value="">
                    -- Select Design --
                </option>

                @foreach (var project in Model.AvailableProjects)
                {
                    foreach (var design in project.Designs)
                    {
                        if (project.ProjectId == Model.ProjectId)
                        {
                            <option value="@design.ResultId"
                                    selected="@(design.ResultId == Model.ResultId)">
                                @design.Label
                            </option>
                        }
                    }
                }

            </select>

        </div>

    </div>

    <div class="d-flex justify-content-between align-items-center mt-4">

        <div>

            @if (!string.IsNullOrWhiteSpace(Model.MaterialUsed))
            {
                <span class="bom-badge bom-badge-auto">
                    @Model.MaterialUsed
                </span>
            }

            @if (Model.ResultId > 0)
            {
                <span class="ms-2 text-muted">
                    Design Result #@Model.ResultId
                </span>
            }

        </div>

        <div class="d-flex gap-2">

            <button id="loadBomBtn"
                    type="button"
                    class="btn btn-outline-primary">
                <i class="bi bi-search"></i>
                Load BOM
            </button>

            @if (Model.ResultId > 0)
            {
                <form asp-controller="Bom"
                      asp-action="Generate"
                      method="post">

                    @Html.AntiForgeryToken()

                    <input type="hidden"
                           name="resultId"
                           value="@Model.ResultId" />

                    <button type="submit"
                            class="btn-regen">

                        <i class="bi bi-arrow-repeat"></i>

                        @(Model.HasBeenGenerated
                                            ? "Regenerate BOM"
                                            : "Generate BOM")

                </button>

                </form>
                        }

        </div>

    </div>

    @if (Model.Warnings.Any())
    {
        <div class="mt-3">
            @foreach (var warning in Model.Warnings)
            {
                <div class="bom-warning">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span>@warning</span>
                </div>
            }
        </div>
    }

    <hr />

    @if (!Model.HasBeenGenerated)
    {
        <div class="bom-empty">

            <i class="bi bi-receipt"
               style="font-size:2rem;"></i>

            <p class="mt-3 mb-0">

                Select a project and design result, then click
                <strong>Generate BOM</strong>.

            </p>

        </div>
    }
    else
    {
        // Categories treated as "Bought-Out" line items.
        var boughtCategories = new[]
        {
        "BoughtOut",
        "Bought-out",
        "Bought-out Component",
        "Hardware",
        "Purchased"
        };

        // Raw material lines: everything auto-generated that isn't a
        // bought-out category and isn't a manually added line.
        var rawLines = Model.Lines
        .Where(x =>
        x.Source != "Manual" &&
        !boughtCategories.Contains(x.Category))
        .ToList();

        var rawTotal = rawLines.Sum(x => x.LineTotal);

        var boughtLines = Model.Lines
        .Where(x => boughtCategories.Contains(x.Category))
        .ToList();

        var boughtTotal = boughtLines.Sum(x => x.LineTotal);

        var manualLines = Model.Lines
        .Where(x => x.Source == "Manual")
        .ToList();

        var manualTotal = manualLines.Sum(x => x.LineTotal);

        <div class="bom-section mt-4">

            <div class="d-flex justify-content-between align-items-center mb-3">

                <h4 class="bom-section-title mb-0">
                    <i class="bi bi-box-seam me-2 text-primary"></i>
                    Raw BOM
                </h4>

                <span class="badge bg-primary">
                    @rawLines.Count Item(s)
                </span>

            </div>

            <table class="bom-table">

                <thead>

                    <tr>

                        <th style="width:40%">Item</th>

                        <th class="text-center">Qty</th>

                        <th class="text-center">Unit</th>

                        <th class="text-end">Rate</th>

                        <th class="text-end">Total</th>

                        <th style="width:55px"></th>

                    </tr>

                </thead>

                <tbody>

                    @if (!rawLines.Any())
                    {
                        <tr>

                            <td colspan="6"
                                class="text-center text-muted py-4">

                                No raw material items generated.

                            </td>

                        </tr>
                    }

                    @foreach (var line in rawLines)
                    {
                        bool isAuto = line.Source != "Manual";

                        <tr>

                            <td>

                                <strong>@line.Description</strong>

                            </td>

                            <td class="text-center">
                                @line.Quantity.ToString("0.##")
                            </td>

                            <td class="text-center">
                                @(string.IsNullOrWhiteSpace(line.Unit) ? "-" : line.Unit)
                            </td>

                            <td class="text-end">
                                ₹@line.UnitCost.ToString("N2")
                            </td>

                            <td class="text-end fw-semibold">
                                ₹@line.LineTotal.ToString("N2")
                            </td>

                            <td class="text-center">

                                @if (isAuto)
                                {
                                    <i class="bi bi-lock-fill text-secondary"
                                       title="Auto generated"></i>
                                }
                                else
                                {
                                    <form asp-controller="Bom"
                                          asp-action="DeleteLine"
                                          method="post"
                                          onsubmit="return confirm('Delete this line item?');">

                                        @Html.AntiForgeryToken()

                                        <input type="hidden"
                                               name="lineItemId"
                                               value="@line.Id" />

                                        <input type="hidden"
                                               name="resultId"
                                               value="@Model.ResultId" />

                                        <button type="submit"
                                                class="btn btn-sm btn-link text-danger p-0">

                                            <i class="bi bi-trash"></i>

                                        </button>

                                    </form>
                                }

                            </td>

                        </tr>
                    }

                    <tr class="bom-total-row">

                        <td colspan="4"
                            class="fw-bold text-end">

                            Raw BOM Total

                        </td>

                        <td class="bom-total-value text-end">

                            ₹@rawTotal.ToString("N2")

                        </td>

                        <td></td>

                    </tr>

                </tbody>

            </table>

        </div>

        <div class="bom-section mt-5">

            <div class="d-flex justify-content-between align-items-center mb-3">

                <h4 class="bom-section-title mb-0">
                    <i class="bi bi-gear-fill me-2 text-success"></i>
                    Bought-Out Components
                </h4>

                <span class="badge bg-success">
                    @boughtLines.Count Item(s)
                </span>

            </div>

            <table class="bom-table">

                <thead>

                    <tr>

                        <th style="width:40%">Item</th>

                        <th class="text-center">Qty</th>

                        <th class="text-center">Unit</th>

                        <th class="text-end">Rate</th>

                        <th class="text-end">Total</th>

                        <th style="width:55px"></th>

                    </tr>

                </thead>

                <tbody>

                    @if (!boughtLines.Any())
                    {
                        <tr>

                            <td colspan="6"
                                class="text-center text-muted py-4">

                                No bought-out components generated.

                            </td>

                        </tr>
                    }

                    @foreach (var line in boughtLines)
                    {
                        bool isAuto = line.Source != "Manual";

                        <tr>

                            <td>
                                <strong>@line.Description</strong>
                            </td>

                            <td class="text-center">
                                @line.Quantity.ToString("0.##")
                            </td>

                            <td class="text-center">
                                @(string.IsNullOrWhiteSpace(line.Unit) ? "-" : line.Unit)
                            </td>

                            <td class="text-end">
                                ₹@line.UnitCost.ToString("N2")
                            </td>

                            <td class="text-end fw-semibold">
                                ₹@line.LineTotal.ToString("N2")
                            </td>

                            <td class="text-center">

                                @if (isAuto)
                                {
                                    <i class="bi bi-lock-fill text-secondary"
                                       title="Auto generated"></i>
                                }
                                else
                                {
                                    <form asp-controller="Bom"
                                          asp-action="DeleteLine"
                                          method="post"
                                          onsubmit="return confirm('Delete this item?');">

                                        @Html.AntiForgeryToken()

                                        <input type="hidden"
                                               name="lineItemId"
                                               value="@line.Id" />

                                        <input type="hidden"
                                               name="resultId"
                                               value="@Model.ResultId" />

                                        <button type="submit"
                                                class="btn btn-sm btn-link text-danger p-0">

                                            <i class="bi bi-trash"></i>

                                        </button>

                                    </form>
                                }

                            </td>

                        </tr>
                    }

                    <tr class="bom-total-row">

                        <td colspan="4"
                            class="fw-bold text-end">

                            Bought BOM Total

                        </td>

                        <td class="bom-total-value text-end">

                            ₹@boughtTotal.ToString("N2")

                        </td>

                        <td></td>

                    </tr>

                </tbody>

            </table>

        </div>

        @if (manualLines.Any())
        {
            <div class="bom-section mt-5">

                <div class="d-flex justify-content-between align-items-center mb-3">

                    <h4 class="bom-section-title mb-0">
                        <i class="bi bi-pencil-square me-2 text-warning"></i>
                        Manual Items
                    </h4>

                    <span class="badge bg-warning text-dark">
                        @manualLines.Count Item(s)
                    </span>

                </div>

                <table class="bom-table">

                    <thead>

                        <tr>

                            <th style="width:40%">Item</th>

                            <th class="text-center">Qty</th>

                            <th class="text-center">Unit</th>

                            <th class="text-end">Rate</th>

                            <th class="text-end">Total</th>

                            <th style="width:55px"></th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var line in manualLines)
                        {
                            <tr>

                                <td>
                                    <strong>@line.Description</strong>
                                </td>

                                <td class="text-center">
                                    @line.Quantity.ToString("0.##")
                                </td>

                                <td class="text-center">
                                    @(string.IsNullOrWhiteSpace(line.Unit) ? "-" : line.Unit)
                                </td>

                                <td class="text-end">
                                    ₹@line.UnitCost.ToString("N2")
                                </td>

                                <td class="text-end fw-semibold">
                                    ₹@line.LineTotal.ToString("N2")
                                </td>

                                <td class="text-center">

                                    <form asp-controller="Bom"
                                          asp-action="DeleteLine"
                                          method="post"
                                          onsubmit="return confirm('Delete this line item?');">

                                        @Html.AntiForgeryToken()

                                        <input type="hidden"
                                               name="lineItemId"
                                               value="@line.Id" />

                                        <input type="hidden"
                                               name="resultId"
                                               value="@Model.ResultId" />

                                        <button type="submit"
                                                class="btn btn-sm btn-link text-danger p-0">

                                            <i class="bi bi-trash"></i>

                                        </button>

                                    </form>

                                </td>

                            </tr>
                        }

                        <tr class="bom-total-row">

                            <td colspan="4"
                                class="fw-bold text-end">

                                Manual Items Total

                            </td>

                            <td class="bom-total-value text-end">

                                ₹@manualTotal.ToString("N2")

                            </td>

                            <td></td>

                        </tr>

                    </tbody>

                </table>

            </div>
        }

        <!-- Grand Total -->

        <div class="bom-card bom-grand-total mt-5">

            <div class="row align-items-center">

                <div class="col-md-8">

                    <h3 class="mb-1">
                        <i class="bi bi-calculator me-2"></i>
                        Total Estimated Cost
                    </h3>

                    <div class="text-muted">

                        Raw Material +
                        Bought-Out Components +
                        Manual Items

                    </div>

                </div>

                <div class="col-md-4 text-end">

                    <h2 class="bom-total-value mb-0">

                        ₹@Model.GrandTotal.ToString("N2")

                    </h2>

                </div>

            </div>

        </div>
    }

</div>   @* <-- closes bom-card *@

@if (Model.ResultId > 0)
{
    <div class="bom-card bom-manual-card mt-4" id="addLineCard">

        <div class="d-flex align-items-center mb-3">

            <i class="bi bi-plus-circle-fill text-success me-2"
               style="font-size:1.4rem;"></i>

            <div>

                <h5 class="mb-0">
                    Add Manual Line Item
                </h5>

                <small class="text-muted">

                    Add vendor supplied items such as castings,
                    bearings, freight, painting, fabrication, etc.

                </small>

            </div>

        </div>

        <form asp-controller="Bom"
              asp-action="AddLine"
              method="post"
              class="row g-3">

            @Html.AntiForgeryToken()

            <input type="hidden"
                   name="resultId"
                   value="@Model.ResultId" />

            <div class="col-md-2">

                <label class="form-label">
                    Category
                </label>

                <select name="category"
                        class="form-select">

                    <option value="Hardware">Hardware</option>

                    <option value="Purchased">Purchased</option>

                    <option value="BoughtOut">Bought Out</option>

                    <option value="Misc">Miscellaneous</option>

                    <option value="Service">Service</option>

                </select>

            </div>

            <div class="col-md-4">

                <label class="form-label">
                    Description
                </label>

                <input type="text"
                       name="description"
                       class="form-control"
                       placeholder="Enter item description"
                       required />

            </div>

            <div class="col-md-1">

                <label class="form-label">
                    Qty
                </label>

                <input type="number"
                       step="0.01"
                       min="0.01"
                       name="quantity"
                       class="form-control"
                       value="1"
                       required />

            </div>

            <div class="col-md-1">

                <label class="form-label">
                    Unit
                </label>

                <input type="text"
                       name="unit"
                       class="form-control"
                       placeholder="Nos" />

            </div>

            <div class="col-md-2">

                <label class="form-label">
                    Unit Cost
                </label>

                <input type="number"
                       step="0.01"
                       min="0"
                       name="unitCost"
                       class="form-control"
                       value="0"
                       required />

            </div>

            <div class="col-md-2 d-grid">

                <label class="form-label">&nbsp;</label>

                <button type="submit"
                        class="btn btn-success">

                    <i class="bi bi-plus-lg me-1"></i>

                    Add Item

                </button>

            </div>

        </form>

    </div>
}

@section Scripts
{
    <script>

        const projects = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AvailableProjects));

        const projectSelect = document.getElementById("projectSelect");
        const designSelect = document.getElementById("designSelect");
        const loadBtn = document.getElementById("loadBomBtn");

        function loadDesigns(projectId, selectedResultId = null)
        {
            designSelect.innerHTML = "";

            const project = projects.find(p => p.ProjectId == projectId);

            if (!project)
            {
                designSelect.innerHTML =
                    '<option value="">-- Select Design --</option>';
                return;
            }

            project.Designs.forEach(function (design)
            {
                const option = document.createElement("option");

                option.value = design.ResultId;
                option.text = design.Label;

                if (selectedResultId &&
                    design.ResultId == selectedResultId)
                {
                    option.selected = true;
                }

                designSelect.appendChild(option);
            });
        }

        projectSelect.addEventListener("change", function ()
        {
            loadDesigns(this.value);
        });

        loadBtn.addEventListener("click", function ()
        {
            if (!designSelect.value)
            {
                alert("Please select a design.");
                return;
            }

            window.location.href =
                "/Bom/Index?resultId=" + designSelect.value;
        });

        document.addEventListener("DOMContentLoaded", function ()
        {
            if (projectSelect.value)
            {
                loadDesigns(
                    projectSelect.value,
                    "@Model.ResultId"
                );
            }
        });

    </script>
}
