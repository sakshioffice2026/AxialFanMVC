@model AxialFanMVC.ViewModels.ReportsViewModel

@{
    ViewData["Title"] = "Reports";
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
    <div>
        <h2 class="mb-1"><i class="bi bi-file-earmark-text me-2 text-primary"></i>Design Reports</h2>
        <p class="text-muted mb-0">Every design you've created, ready to export.</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-danger btn-sm"
           asp-action="ExportPdf"
           asp-route-projectId="@Model.SelectedProjectId"
           asp-route-status="@Model.SelectedStatus">
            <i class="bi bi-file-earmark-pdf me-1"></i>Export PDF
        </a>
        <a class="btn btn-outline-success btn-sm"
           asp-action="ExportExcel"
           asp-route-projectId="@Model.SelectedProjectId"
           asp-route-status="@Model.SelectedStatus">
            <i class="bi bi-file-earmark-excel me-1"></i>Export Excel
        </a>
    </div>
</div>

<form asp-controller="Reports" asp-action="Index" method="get"
      class="d-flex flex-wrap align-items-center gap-2 mb-3">
    <label class="form-label fw-semibold mb-0 small">Project</label>
    <select name="projectId" class="form-select form-select-sm" style="width:220px" onchange="this.form.submit()">
        <option value="">All Projects</option>
        @foreach (var p in Model.ProjectFilterOptions)
        {
            <option value="@p.Id" selected="@(Model.SelectedProjectId == p.Id)">@p.Name</option>
        }
    </select>

    <label class="form-label fw-semibold mb-0 small ms-2">Status</label>
    <select name="status" class="form-select form-select-sm" style="width:160px" onchange="this.form.submit()">
        <option value="" selected="@(string.IsNullOrEmpty(Model.SelectedStatus))">All</option>
        <option value="ok" selected="@(Model.SelectedStatus == "ok")">OK</option>
        <option value="warning" selected="@(Model.SelectedStatus == "warning")">Warning</option>
        <option value="pending" selected="@(Model.SelectedStatus == "pending")">Pending</option>
    </select>
</form>

<p class="text-muted small mb-3">
    @Model.TotalDesigns design(s) &nbsp;|&nbsp;
    <span class="text-success">@Model.CalculatedCount OK</span> &nbsp;|&nbsp;
    <span class="text-warning">@Model.WarningCount warning</span> &nbsp;|&nbsp;
    <span class="text-secondary">@Model.PendingCount pending</span>
</p>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table mb-0 align-middle">
            <thead>
                <tr>
                    <th>Project</th>
                    <th>Application</th>
                    <th>Media</th>
                    <th>Flow Rate</th>
                    <th>Total Pressure</th>
                    <th>Speed</th>
                    <th>Blades</th>
                    <th>Tip Dia.</th>
                    <th>Efficiency</th>
                    <th>Shaft Power</th>
                    <th>Safety Factor</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Designs.Any())
                {
                    <tr><td colspan="14" class="text-center text-muted py-4">No designs found for this filter.</td></tr>
                }
                else
                {
                    @foreach (var d in Model.Designs)
                    {
                        <tr>
                            <td>@d.ProjectName</td>
                            <td>@(d.Application ?? "-")</td>
                            <td>@d.MediaType</td>
                            <td>@d.FlowRateM3s.ToString("F2") m³/s</td>
                            <td>@d.TotalPressurePa.ToString("F0") Pa</td>
                            <td>@d.SpeedRpm RPM</td>
                            <td>@d.BladeCount</td>
                            <td>@d.TipDiameterMm.ToString("F0") mm</td>
                            <td>@(d.OverallEfficiencyPct.HasValue? d.OverallEfficiencyPct.Value.ToString("F1") + "%" : "-")</td>
                            <td>@(d.ShaftPowerKw.HasValue? d.ShaftPowerKw.Value.ToString("F2") + " kW" : "-")</td>
                            <td>@(d.SafetyFactor.HasValue? d.SafetyFactor.Value.ToString("F2") : "-")</td>
                            <td>
                                @switch (d.Status)
                                {
                                    case "ok":
                                        <span class="badge bg-success">OK</span>
                                        break;
                                    case "warning":
                                        <span class="badge bg-warning text-dark">Warning</span>
                                        break;
                                    default:
                                        <span class="badge bg-secondary">Pending</span>
                                        break;
                                }
                            </td>
                            <td>@d.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td>
                                @if (d.ResultId.HasValue)
                                {
                                    <div class="d-flex gap-1">
                                        <a asp-controller="Results" asp-action="Result" asp-route-resultId="@d.ResultId" class="btn btn-sm btn-outline-primary">View</a>
                                        <a asp-controller="Export" asp-action="EyeshotPdf" asp-route-resultId="@d.ResultId" class="btn btn-sm btn-outline-danger" title="Download PDF">
                                            <i class="bi bi-file-earmark-pdf"></i>
                                        </a>
                                        <a asp-controller="Export" asp-action="ChartsOnlyPdf" asp-route-resultId="@d.ResultId" class="btn btn-sm btn-outline-warning" title="Download Charts">
                                            <i class="bi bi-graph-up"></i>
                                        </a>
                                        <a asp-controller="Export" asp-action="Excel" asp-route-resultId="@d.ResultId" class="btn btn-sm btn-outline-success" title="Download Excel">
                                            <i class="bi bi-file-earmark-excel"></i>
                                        </a>
                                        <a asp-controller="Export" asp-action="Word" asp-route-resultId="@d.ResultId" class="btn btn-sm btn-outline-info" title="Download Word">
                                            <i class="bi bi-file-earmark-word"></i>
                                        </a>
                                    </div>
                                }
                                else
                                {
                                    <a asp-controller="Design" asp-action="EditInput" asp-route-designInputId="@d.DesignInputId" class="btn btn-sm btn-primary">Calculate</a>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>