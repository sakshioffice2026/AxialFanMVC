@model AxialFanMVC.Models.BladeProfileDetailViewModel

@if (Model == null)
{
    <div class="text-muted small text-center py-2">No profile data available.</div>
}
else
{
<div class="row g-3">

    @* Left: SVG aerofoil drawing *@
    <div class="col-lg-7">
        <div class="border rounded overflow-hidden bg-white text-center"
             style="height:220px;display:flex;align-items:center;justify-content:center">
            @Html.Raw(Model.SvgProfile)
        </div>
        <p class="text-muted text-center mt-1" style="font-size:10px">
            @Model.Name — Chord = @Model.ChordMm.ToString("F1") mm
        </p>
    </div>

    @* Right: Key dimensions *@
    <div class="col-lg-5">

        <div class="d-flex gap-2 mb-2 flex-wrap">
            <span class="badge bg-primary-subtle text-primary border border-primary-subtle">
                @Model.Type
            </span>
            <span class="badge bg-secondary-subtle text-secondary">
                Camber @Model.MaxCamberPct.ToString("F1")%
            </span>
            <span class="badge bg-secondary-subtle text-secondary">
                Thickness @Model.MaxThicknessPct.ToString("F1")%
            </span>
        </div>

        <div class="mb-2" style="font-size:11.5px">
            @{
                void Row(string label, string val)
                {
                    <div class="d-flex justify-content-between py-1"
                         style="border-bottom:0.5px solid #f0f0f0">
                        <span class="text-secondary">@label</span>
                        <span class="fw-medium text-dark">@val</span>
                    </div>
                }
            }
            @{ Row("Chord",           Model.Dimensions.ChordMm.ToString("F1") + " mm"); }
            @{ Row("Max thickness",   Model.Dimensions.MaxThicknessMm.ToString("F2") + " mm (" + Model.Dimensions.MaxThicknessPct.ToString("F1") + "%)"); }
            @{ Row("Max camber",      Model.Dimensions.MaxCamberMm.ToString("F2") + " mm (" + Model.Dimensions.MaxCamberPct.ToString("F1") + "%)"); }
            @{ Row("LE radius",       Model.Dimensions.LeadingEdgeRadiusMm.ToString("F2") + " mm"); }
            @{ Row("Design Cl",       Model.AeroParams.DesignLiftCoeff.ToString("F3")); }
            @{ Row("Stall angle",     "~" + Model.AeroParams.ApproxStallAngle.ToString("F0") + "°"); }
            @{ Row("Zero-lift angle", Model.AeroParams.ApproxZeroLiftAngle.ToString("F1") + "°"); }
        </div>

        <a asp-controller="BladeProfiles" asp-action="Detail"
           asp-route-id="@Model.Id" asp-route-chord="@Model.ChordMm"
           target="_blank" class="btn btn-outline-primary btn-sm mt-1" style="font-size:11px">
            <i class="bi bi-box-arrow-up-right me-1"></i>Full profile detail
        </a>
    </div>
</div>
}
