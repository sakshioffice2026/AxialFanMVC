@model AxialFanMVC.Models.HandbookSearchViewModel

@{
    ViewData["Title"] = "Reference Search";
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
    <div>
        <h2 class="mb-1"><i class="bi bi-book me-2 text-primary"></i>Engineering Reference Library</h2>
        <p class="text-muted mb-0">Search axial-fan design guidance and reference material.</p>
    </div>
</div>

<form asp-controller="Handbook" asp-action="Index" method="get"
      class="d-flex flex-wrap align-items-center gap-2 mb-4">
    <input type="text" name="query" value="@Model.Query"
           class="form-control" style="max-width:420px"
           placeholder="e.g. blade tip clearance, static pressure loss..." />
    <button type="submit" class="btn btn-primary">
        <i class="bi bi-search me-1"></i>Search
    </button>
</form>

@if (!string.IsNullOrWhiteSpace(Model.Query))
{
    <p class="text-muted small mb-3">
        @Model.Results.Count result(s) for "<strong>@Model.Query</strong>"
    </p>

    if (Model.Results.Count == 0)
    {
        <div class="alert alert-secondary">
            No matches found. Try different or fewer keywords.
        </div>
    }

    @foreach (var r in Model.Results)
    {
        <div class="card border-0 shadow-sm mb-3" style="border-radius:10px;">
            <div class="card-body px-4 py-3">
                @if (!string.IsNullOrWhiteSpace(r.Section))
                {
                    <div class="text-uppercase text-muted mb-2" style="font-size:0.72rem; letter-spacing:0.06em;">
                        @r.Section
                    </div>
                }

                @if (r.MayContainScanArtifacts)
                {
                    <div class="alert alert-warning py-2 px-3 small mb-0" style="border-radius:8px;">
                        <i class="bi bi-exclamation-triangle me-1"></i>
                        This source material didn't convert cleanly — verify against the original before relying on it.
                    </div>
                }
                else
                {
                    <ul class="mb-0 ps-3" style="line-height:1.7;">
                        @foreach (var bullet in r.Bullets)
                        {
                            <li>@bullet</li>
                        }
                    </ul>
                }
            </div>
        </div>
    }
}
