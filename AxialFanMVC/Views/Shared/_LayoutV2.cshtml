@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    var isHomePage = currentController.Equals("Home", StringComparison.OrdinalIgnoreCase)
                     && currentAction.Equals("Index", StringComparison.OrdinalIgnoreCase);

    var isLoginPage = currentController.Equals("Account", StringComparison.OrdinalIgnoreCase)
                      && (currentAction.Equals("Login", StringComparison.OrdinalIgnoreCase)
                       || currentAction.Equals("Register", StringComparison.OrdinalIgnoreCase));

    var showSidebar = User.Identity?.IsAuthenticated == true && !isHomePage && !isLoginPage;

    string NavClass(string controller) =>
    currentController.Equals(controller, StringComparison.OrdinalIgnoreCase)
        ? "v2-nav-link active"
        : "v2-nav-link";

    string NavActionClass(string controller, string action) =>
        currentController.Equals(controller, StringComparison.OrdinalIgnoreCase) &&
        currentAction.Equals(action, StringComparison.OrdinalIgnoreCase)
            ? "v2-nav-link active"
            : "v2-nav-link";
}

<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>
        @(ViewData["Title"] ?? "AxialFlow Designer")
    </title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link rel="stylesheet"
          href="~/css/layout-v2.css"
          asp-append-version="true" />

    @RenderSection("Styles", required: false)

</head>

<body>

    <div class="v2-shell @(showSidebar ? "" : "v2-no-sidebar")">

        @if (User.Identity?.IsAuthenticated == true)
        {
            <partial name="_ChatWidget" />
        }

        @if (showSidebar)
        {
            <aside class="v2-sidebar">

                <a asp-controller="Home"
                   asp-action="Index"
                   class="v2-brand">

                    <i class="bi bi-fan"></i>

                    <span>AxialFlow Designer</span>

                </a>

                <ul class="v2-nav">

                    <!-- ========================= -->
                    <!-- DASHBOARD -->
                    <!-- ========================= -->

                    <li class="v2-nav-item">

                        <a asp-controller="Dashboard"
                           asp-action="Index"
                           class="@NavClass("Dashboard")">

                            <i class="bi bi-speedometer2 v2-nav-icon"></i>

                            <span>Dashboard</span>

                        </a>

                    </li>

                    <!-- ========================= -->
                    <!-- DESIGN -->
                    <!-- ========================= -->
                    <li class="v2-nav-item">

                        @* Design/New auto-selects the user's most recently updated
                       project and redirects into that project's wizard — no
                       picker needed if a project already exists. Falls back to
                       Projects/Create only when the user has zero projects. *@
                        <a asp-controller="Design"
                           asp-action="New"
                           class="@NavActionClass("Design", "Wizard")">

                            <i class="bi bi-plus-circle v2-nav-icon"></i>

                            <span>New Design</span>

                        </a>

                    </li>

                    <li class="v2-nav-item">

                        <a asp-controller="Projects"
                           asp-action="Index"
                           class="@NavClass("Projects")">

                            <i class="bi bi-folder2-open v2-nav-icon"></i>

                            <span>Projects</span>

                        </a>

                    </li>

                    @* <li class="v2-nav-item">

                        <a asp-controller="DesignSeries"
                           asp-action="Index"
                           class="@NavClass("DesignSeries")">

                            <i class="bi bi-layers v2-nav-icon"></i>

                            <span>Design Series</span>

                        </a>

                    </li> *@

                    @* <li class="v2-nav-item">

                        <a asp-controller="Results"
                           asp-action="Index"
                           class="@NavClass("Results")">

                            <i class="bi bi-graph-up-arrow v2-nav-icon"></i>

                            <span>Results</span>

                        </a>

                    </li> *@

                    <li class="v2-nav-item">

                        <a asp-controller="Bom"
                           asp-action="Index"
                           class="@NavClass("Bom")">

                            <i class="bi bi-receipt v2-nav-icon"></i>

                            <span>BOM &amp; Costing</span>

                        </a>

                    </li>

                    <hr />

                    <!-- ========================= -->
                    <!-- ENGINEERING -->
                    <!-- ========================= -->

                    <li class="v2-nav-item">

                        <a asp-controller="BladeProfiles"
                           asp-action="Index"
                           class="@NavClass("BladeProfiles")">

                            <i class="bi bi-bezier2 v2-nav-icon"></i>

                            <span>Blade Profiles</span>

                        </a>

                    </li>

                    <li class="v2-nav-item">

                        <a asp-controller="CalibrationCases"
                           asp-action="Index"
                           class="@NavClass("CalibrationCases")">

                            <i class="bi bi-clipboard-data v2-nav-icon"></i>

                            <span>Calibration Cases</span>

                        </a>

                    </li>

                    <li class="v2-nav-item">

                        <a asp-controller="Reports"
                           asp-action="Index"
                           class="@NavClass("Reports")">

                            <i class="bi bi-bar-chart-line v2-nav-icon"></i>

                            <span>Reports</span>

                        </a>

                    </li>

                    <hr />

                    <!-- ========================= -->
                    <!-- KNOWLEDGE -->
                    <!-- ========================= -->

                    <li class="v2-nav-item">

                        <a asp-controller="Handbook"
                           asp-action="Index"
                           class="@NavClass("Handbook")">

                            <i class="bi bi-book v2-nav-icon"></i>

                            <span>Engineering Reference</span>

                        </a>

                    </li>

                    <li class="v2-nav-item">

                        <a asp-controller="Chat"
                           asp-action="Index"
                           class="@NavClass("Chat")">

                            <i class="bi bi-robot v2-nav-icon"></i>

                            <span>AI Assistant</span>

                        </a>

                    </li>

                    <hr />

                    <!-- ========================= -->
                    <!-- FUTURE MODULES -->
                    <!-- ========================= -->

                    <li class="v2-nav-item">

                        <a class="v2-nav-link soon">

                            <i class="bi bi-hdd-stack v2-nav-icon"></i>

                            <span>Fan Database</span>

                            <span class="v2-soon-tag">
                                Soon
                            </span>

                        </a>

                    </li>

                    <li class="v2-nav-item">

                        <a class="v2-nav-link soon">

                            <i class="bi bi-file-earmark-text v2-nav-icon"></i>

                            <span>My Drawings</span>

                            <span class="v2-soon-tag">
                                Soon
                            </span>

                        </a>

                    </li>

                    <li class="v2-nav-item">

                        <a class="v2-nav-link soon">

                            <i class="bi bi-gear v2-nav-icon"></i>

                            <span>Settings</span>

                            <span class="v2-soon-tag">
                                Soon
                            </span>

                        </a>

                    </li>

                    <li class="v2-nav-item">

                        <a class="v2-nav-link soon">

                            <i class="bi bi-question-circle v2-nav-icon"></i>

                            <span>Help</span>

                            <span class="v2-soon-tag">
                                Soon
                            </span>

                        </a>

                    </li>

                </ul>

                <div class="v2-sidebar-footer">

                    © @DateTime.Now.Year AxialFlow Designer

                </div>

            </aside>
        }

        <div class="v2-main">
            <div class="v2-topbar">

                <div class="d-flex align-items-center">

                    @if (!isHomePage)
                    {
                        <a href="javascript:history.back()"
                           class="v2-back-btn">

                            <i class="bi bi-arrow-left"></i>

                            Back

                        </a>
                    }

                    <div class="ms-3">

                        <h5 class="mb-0 fw-semibold">

                            @(ViewData["Title"] ?? currentController)

                        </h5>

                        <small class="text-muted">

                            AxialFlow Designer

                        </small>

                    </div>

                </div>

                <div class="v2-user-menu">

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="dropdown">

                            <a href="#"
                               class="dropdown-toggle text-decoration-none"
                               data-bs-toggle="dropdown">

                                <i class="bi bi-person-circle me-1"></i>

                                @User.Identity?.Name

                            </a>

                            <ul class="dropdown-menu dropdown-menu-end shadow">

                                <li>

                                    <span class="dropdown-item-text">

                                        Signed in as

                                        <strong>

                                            @User.Identity?.Name

                                        </strong>

                                    </span>

                                </li>

                                <li>
                                    <hr class="dropdown-divider" />
                                </li>

                                <li>

                                    <a asp-controller="Projects"
                                       asp-action="Index"
                                       class="dropdown-item">

                                        <i class="bi bi-folder2-open me-2"></i>

                                        My Projects

                                    </a>

                                </li>

                                <li>

                                    <a asp-controller="Reports"
                                       asp-action="Index"
                                       class="dropdown-item">

                                        <i class="bi bi-bar-chart me-2"></i>

                                        Reports

                                    </a>

                                </li>

                                <li>

                                    <a asp-controller="Handbook"
                                       asp-action="Index"
                                       class="dropdown-item">

                                        <i class="bi bi-book me-2"></i>

                                        Handbook

                                    </a>

                                </li>

                                <li>
                                    <hr class="dropdown-divider" />
                                </li>

                                <li>

                                    <form asp-controller="Account"
                                          asp-action="Logout"
                                          method="post">

                                        @Html.AntiForgeryToken()

                                        <button type="submit"
                                                class="dropdown-item text-danger">

                                            <i class="bi bi-box-arrow-right me-2"></i>

                                            Sign Out

                                        </button>

                                    </form>

                                </li>

                            </ul>

                        </div>
                    }
                    else
                    {
                        <a asp-controller="Account"
                           asp-action="Login"
                           class="v2-back-btn me-2">

                            <i class="bi bi-box-arrow-in-right"></i>

                            Login

                        </a>

                        <a asp-controller="Account"
                           asp-action="Register"
                           class="v2-back-btn">

                            <i class="bi bi-person-plus"></i>

                            Register

                        </a>
                    }

                </div>

            </div>

            <div class="v2-content">

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show shadow-sm">

                        <i class="bi bi-check-circle-fill me-2"></i>

                        @TempData["Success"]

                        <button type="button"
                                class="btn-close"
                                data-bs-dismiss="alert"></button>

                    </div>
                }

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show shadow-sm">

                        <i class="bi bi-exclamation-triangle-fill me-2"></i>

                        @TempData["Error"]

                        <button type="button"
                                class="btn-close"
                                data-bs-dismiss="alert"></button>

                    </div>
                }

                @if (TempData["Warning"] != null)
                {
                    <div class="alert alert-warning alert-dismissible fade show shadow-sm">

                        <i class="bi bi-exclamation-circle me-2"></i>

                        @TempData["Warning"]

                        <button type="button"
                                class="btn-close"
                                data-bs-dismiss="alert"></button>

                    </div>
                }

                @RenderBody()

            </div>

            <footer class="v2-footer">

                <div class="d-flex justify-content-between align-items-center flex-wrap">

                    <div>

                        © @DateTime.Now.Year

                        <strong>AxialFlow Designer</strong>

                    </div>

                    <div class="text-muted">

                        Professional Turbomachinery Design Platform

                    </div>

                </div>

            </footer>

        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>
