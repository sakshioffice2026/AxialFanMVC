@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    var isMainPage = currentController.Equals("Home", StringComparison.OrdinalIgnoreCase)
                      && currentAction.Equals("Index", StringComparison.OrdinalIgnoreCase);

    var isLoginPage = currentController.Equals("Account", StringComparison.OrdinalIgnoreCase)
                       && (currentAction.Equals("Login", StringComparison.OrdinalIgnoreCase)
                           || currentAction.Equals("Register", StringComparison.OrdinalIgnoreCase));

    // Sidebar only shows once logged in, and never on the landing or auth pages.
    var showSidebar = User.Identity?.IsAuthenticated == true && !isMainPage && !isLoginPage;

    string NavClass(string controllerName) =>
        currentController.Equals(controllerName, StringComparison.OrdinalIgnoreCase)
            ? "v2-nav-link active"
            : "v2-nav-link";

    string NavClassByAction(string controllerName, string actionName) =>
        currentController.Equals(controllerName, StringComparison.OrdinalIgnoreCase)
        && currentAction.Equals(actionName, StringComparison.OrdinalIgnoreCase)
            ? "v2-nav-link active"
            : "v2-nav-link";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — AxialFlow Designer</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/layout-v2.css" asp-append-version="true" />
</head>
<body>
    <div class="v2-shell @(showSidebar ? "" : "v2-no-sidebar")">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <partial name="_ChatWidget" />
        }
        @if (showSidebar)
        {
            <aside class="v2-sidebar">
                <a class="v2-brand" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-fan"></i> AxialFlow Designer
                </a>

                <ul class="v2-nav">
                    <li class="v2-nav-item">
                        <a class="@NavClass("SectionPreview")" asp-controller="SectionPreview" asp-action="Dashboard">
                            <i class="bi bi-speedometer2 v2-nav-icon"></i> Dashboard
                        </a>
                    </li>
                    <li class="v2-nav-item">
                        <a class="@NavClassByAction("SectionPreview", "DesignWizard")" asp-controller="SectionPreview" asp-action="DesignWizard">
                            <i class="bi bi-plus-circle v2-nav-icon"></i> New Design
                        </a>
                    </li>
                    <li class="v2-nav-item">
                        <a class="@NavClass("Projects")" asp-controller="Projects" asp-action="Index">
                            <i class="bi bi-folder v2-nav-icon"></i> Design Projects
                        </a>
                    </li>
                    <li class="v2-nav-item">
                        <a class="@NavClassByAction("DesignSeries", "Index")" asp-controller="DesignSeries" asp-action="Index">
                            <i class="bi bi-layers v2-nav-icon"></i> Design Series
                        </a>
                    </li>
                    <li class="v2-nav-item">
                        <a class="@NavClass("BladeProfiles")" asp-controller="BladeProfiles" asp-action="Index">
                            <i class="bi bi-database v2-nav-icon"></i> Blade Profiles
                        </a>
                    </li>
                    <li class="v2-nav-item">
                        <a class="@NavClassByAction("SectionPreview", "FanDatabase")" asp-controller="SectionPreview" asp-action="FanDatabase">
                            <i class="bi bi-hdd-stack v2-nav-icon"></i> Fan Database
                        </a>
                    </li>
                    <li class="v2-nav-item">
                        <a class="@NavClassByAction("SectionPreview", "MyDrawings")" asp-controller="SectionPreview" asp-action="MyDrawings">
                            <i class="bi bi-file-earmark-text v2-nav-icon"></i> My Drawings
                        </a>
                    </li>
                    <li class="v2-nav-item">
                        <a class="@NavClassByAction("Reports", "Index")" asp-controller="Reports" asp-action="Index">
                            <i class="bi bi-bar-chart v2-nav-icon"></i> Reports
                        </a>
                    </li>
                    <li class="v2-nav-item">
                        <a class="@NavClassByAction("SectionPreview", "BomCosting")" asp-controller="SectionPreview" asp-action="BomCosting">
                            <i class="bi bi-receipt v2-nav-icon"></i> BOM &amp; Costing
                        </a>
                    </li>
                    <li class="v2-nav-item">
                        <a class="@NavClassByAction("SectionPreview", "Settings")" asp-controller="SectionPreview" asp-action="Settings">
                            <i class="bi bi-gear v2-nav-icon"></i> Settings
                        </a>
                    </li>
                    <li class="v2-nav-item">
                        <a class="@NavClassByAction("SectionPreview", "Help")" asp-controller="SectionPreview" asp-action="Help">
                            <i class="bi bi-question-circle v2-nav-icon"></i> Help
                        </a>
                    </li>
                </ul>

                <div class="v2-sidebar-footer">
                    &copy; @DateTime.Now.Year AxialFlow Designer
                </div>
            </aside>
        }

        <div class="v2-main">
            <div class="v2-topbar">
                <div>
                    @if (!isMainPage)
                    {
                        <a href="javascript:history.back()" class="v2-back-btn">
                            <i class="bi bi-arrow-left"></i> Back
                        </a>
                    }
                </div>

                <div class="v2-user-menu">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="dropdown">
                            <a class="dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-1"></i>@User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-right me-1"></i>Sign Out
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="v2-back-btn me-2">
                            <i class="bi bi-box-arrow-in-right"></i> Login
                        </a>
                        <a asp-controller="Account" asp-action="Register" class="v2-back-btn">
                            <i class="bi bi-person-plus"></i> Register
                        </a>
                    }
                </div>
            </div>
            <div class="v2-content">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show shadow-sm">
                        <i class="bi bi-check-circle-fill me-1"></i>@TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show shadow-sm">
                        <i class="bi bi-exclamation-circle-fill me-1"></i>@TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @RenderBody()
            </div>

            <div class="v2-footer">
                AxialFlow Designer &mdash; Professional Turbomachinery Design Tool
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>